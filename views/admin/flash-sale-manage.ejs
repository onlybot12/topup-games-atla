<!DOCTYPE html>
<html lang="id">
<head>
    <title>Admin - Kelola Flash Sale</title>
    <%- include('../partials/head') %>
</head>
<body class="bg-slate-50">
    <%- include('../partials/sidebar') %>
    <div id="main-content" class="lg:ml-64 min-h-screen">
        <header class="h-16 bg-white border-b px-6 flex items-center justify-between sticky top-0 z-40">
            <h1 class="font-bold text-slate-800 text-sm uppercase">Flash Sale / Promo Terbatas</h1>
            <button onclick="addFlashSale()" class="bg-blue-600 text-white px-4 py-2 rounded-xl text-[10px] font-black uppercase shadow-lg shadow-blue-500/20">
                <i class="fas fa-plus mr-1"></i> Tambah Promo
            </button>
        </header>

        <main class="p-4 md:p-6">
            <div id="fs-list" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                <!-- Data Flash Sale -->
            </div>
        </main>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.0.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        async function loadFlashSales() {
            const res = await fetch('/api/admin/flash-sales');
            const json = await res.json();
            const grid = $('#fs-list').empty();
            
            json.data.forEach(f => {
                grid.append(`
                    <div class="bg-white p-5 rounded-[28px] border shadow-sm relative overflow-hidden">
                        <div class="absolute top-0 right-0 bg-yellow-400 text-slate-900 text-[9px] font-black px-3 py-1 rounded-bl-xl uppercase">Flash Sale</div>
                        <h3 class="font-black text-slate-800 text-sm mb-1 uppercase">${f.item_name}</h3>
                        <p class="text-[10px] text-slate-400 font-bold mb-4">ID: ${f.service_id}</p>
                        
                        <div class="flex justify-between items-end border-t pt-4">
                            <div>
                                <p class="text-[9px] text-slate-400 font-bold line-through">Rp ${f.original_price.toLocaleString()}</p>
                                <p class="text-blue-600 font-black text-lg leading-none">Rp ${f.promo_price.toLocaleString()}</p>
                            </div>
                            <button onclick="deleteFS('${f._id}')" class="text-red-500 hover:scale-110 transition-transform"><i class="fas fa-trash"></i></button>
                        </div>
                        <p class="text-[9px] text-slate-400 mt-3 font-bold uppercase"><i class="fas fa-clock mr-1 text-blue-500"></i> Berakhir: ${new Date(f.end_date).toLocaleString()}</p>
                    </div>
                `);
            });
        }

        async function addFlashSale() {
            const { value: f } = await Swal.fire({
                title: 'Set Promo Flash Sale',
                html: `
                    <div class="text-left">
                        <label class="text-[10px] font-bold text-slate-400 uppercase">Nama Item</label>
                        <input id="f-name" class="swal2-input !mt-1 !text-sm" placeholder="Contoh: 100 Diamond ML">
                        <label class="text-[10px] font-bold text-slate-400 uppercase">Service ID (Atlantic)</label>
                        <input id="f-sid" class="swal2-input !mt-1 !text-sm" placeholder="ASPxxx">
                        <label class="text-[10px] font-bold text-slate-400 uppercase">Harga Asli</label>
                        <input id="f-original" type="number" class="swal2-input !mt-1 !text-sm">
                        <label class="text-[10px] font-bold text-slate-400 uppercase">Harga Promo</label>
                        <input id="f-promo" type="number" class="swal2-input !mt-1 !text-sm">
                        <label class="text-[10px] font-bold text-slate-400 uppercase">Waktu Berakhir (DateTime)</label>
                        <input id="f-end" type="datetime-local" class="swal2-input !mt-1 !text-sm">
                    </div>
                `,
                preConfirm: () => ({
                    item_name: $('#f-name').val(),
                    service_id: $('#f-sid').val(),
                    original_price: $('#f-original').val(),
                    promo_price: $('#f-promo').val(),
                    end_date: $('#f-end').val()
                })
            });
            if(f) {
                await fetch('/api/admin/flash-sales', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify(f) });
                loadFlashSales();
            }
        }

        async function deleteFS(id) {
            await fetch(`/api/admin/flash-sales/${id}`, { method: 'DELETE' });
            loadFlashSales();
        }

        $(document).ready(loadFlashSales);
    </script>
</body>
</html>
