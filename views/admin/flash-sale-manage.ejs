<!DOCTYPE html>
<html lang="id">
<head>
    <title>Admin - Flash Sale</title>
    <%- include('../partials/head') %>
</head>
<body class="bg-slate-50 overflow-x-hidden">
    <%- include('../partials/sidebar') %>
    <div id="main-content" class="lg:ml-64 min-h-screen">
        <!-- HEADER DENGAN HAMBURGER -->
        <header class="h-16 bg-white border-b border-slate-200 sticky top-0 z-40 px-4 flex items-center justify-between">
            <div class="flex items-center gap-3">
                <button onclick="toggleSidebar()" class="lg:hidden w-10 h-10 flex items-center justify-center rounded-xl bg-slate-50 border text-slate-600 active:scale-95 transition-all">
                    <i class="fas fa-bars-staggered"></i>
                </button>
                <h1 class="font-bold text-slate-800 text-sm uppercase">Flash Sale</h1>
            </div>
            <button onclick="addFlashSale()" class="bg-blue-600 text-white px-4 py-2 rounded-xl text-[10px] font-black uppercase shadow-lg">
                <i class="fas fa-plus mr-1"></i> Promo
            </button>
        </header>

        <main class="p-4 md:p-6">
            <div id="fs-list" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4"></div>
        </main>
    </div>
    <!-- (Script loadFlashSales, addFlashSale, deleteFS sama seperti sebelumnya) -->
    <script src="https://code.jquery.com/jquery-3.7.0.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        async function loadFlashSales() {
            const res = await fetch('/api/admin/flash-sales');
            const json = await res.json();
            const grid = $('#fs-list').empty();
            json.data.forEach(f => {
                grid.append(`
                    <div class="bg-white p-5 rounded-[28px] border shadow-sm relative overflow-hidden">
                        <h3 class="font-black text-slate-800 text-xs uppercase mb-4">${f.item_name}</h3>
                        <div class="flex justify-between items-end border-t pt-4">
                            <div>
                                <p class="text-[9px] text-slate-400 line-through">Rp ${f.original_price.toLocaleString()}</p>
                                <p class="text-blue-600 font-black text-base leading-none">Rp ${f.promo_price.toLocaleString()}</p>
                            </div>
                            <button onclick="deleteFS('${f._id}')" class="text-red-500"><i class="fas fa-trash"></i></button>
                        </div>
                    </div>
                `);
            });
        }
        async function addFlashSale() {
            const { value: f } = await Swal.fire({
                title: 'Set Promo',
                html: `<input id="f-name" class="swal2-input" placeholder="Nama Item"><input id="f-sid" class="swal2-input" placeholder="ID Layanan"><input id="f-original" type="number" class="swal2-input" placeholder="Harga Asli"><input id="f-promo" type="number" class="swal2-input" placeholder="Harga Promo"><input id="f-end" type="datetime-local" class="swal2-input">`,
                preConfirm: () => ({ item_name: $('#f-name').val(), service_id: $('#f-sid').val(), original_price: $('#f-original').val(), promo_price: $('#f-promo').val(), end_date: $('#f-end').val() })
            });
            if(f) { await fetch('/api/admin/flash-sales', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify(f) }); loadFlashSales(); }
        }
        async function deleteFS(id) { await fetch(`/api/admin/flash-sales/${id}`, { method: 'DELETE' }); loadFlashSales(); }
        $(document).ready(loadFlashSales);
    </script>
</body>
</html>
