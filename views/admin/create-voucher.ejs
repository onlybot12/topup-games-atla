<!DOCTYPE html>
<html lang="id">
<head>
    <title>Lana Admin - Voucher Promo</title>
    <%- include('../partials/head') %>
    <style>
        .voucher-card { background: white; border-radius: 24px; border: 1px solid #e2e8f0; padding: 20px; shadow-sm; }
    </style>
</head>
<body class="overflow-x-hidden">

    <%- include('../partials/sidebar') %>

    <div id="main-content" class="lg:ml-64 min-h-screen">
        <header class="h-16 bg-white border-b border-slate-200 sticky top-0 z-40 px-4 flex items-center justify-between">
            <div class="flex items-center gap-3">
                <button onclick="toggleSidebar()" class="lg:hidden w-10 h-10 flex items-center justify-center rounded-xl bg-slate-50 text-slate-600 border">
                    <i class="fas fa-bars-staggered"></i>
                </button>
                <h1 class="font-bold text-slate-800">Promo Voucher</h1>
            </div>
            <button onclick="openVoucherModal()" class="bg-slate-900 text-white px-4 py-2 rounded-xl text-[10px] font-black uppercase">
                <i class="fas fa-plus mr-1"></i> Baru
            </button>
        </header>

        <main class="p-4 md:p-6">
            <div id="voucher-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                <!-- Data vouchers ditarik via AJAX -->
            </div>
        </main>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.0.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        async function loadVouchers() {
            const res = await fetch('/api/admin/vouchers');
            const json = await res.json();
            const grid = $('#voucher-grid').empty();
            
            if(json.data.length === 0) {
                return grid.html('<p class="text-center text-slate-400 py-20 col-span-full">Belum ada voucher aktif.</p>');
            }
            
            json.data.forEach(v => {
                const percent = (v.used_count / v.quota) * 100;
                grid.append(`
                    <div class="voucher-card">
                        <div class="flex justify-between items-start mb-4">
                            <div>
                                <p class="text-[9px] font-black text-blue-500 uppercase tracking-widest mb-1">
                                    ${v.type === 'percentage' ? 'Potongan %' : 'Potongan Tunai'}
                                </p>
                                <h3 class="text-xl font-black text-slate-800 uppercase">${v.code}</h3>
                            </div>
                            <button onclick="deleteVoucher('${v._id}')" class="w-8 h-8 bg-red-50 text-red-500 rounded-lg">
                                <i class="fas fa-trash-alt text-xs"></i>
                            </button>
                        </div>
                        <p class="text-2xl font-black text-slate-900 mb-6">
                            ${v.type === 'percentage' ? v.value + '%' : 'Rp ' + v.value.toLocaleString()}
                        </p>
                        <div class="bg-slate-50 p-4 rounded-2xl">
                            <div class="flex justify-between text-[10px] font-black mb-2">
                                <span class="text-slate-400 uppercase font-bold">PENGGUNAAN</span>
                                <span class="text-slate-800">${v.used_count}/${v.quota}</span>
                            </div>
                            <div class="w-full h-2 bg-slate-200 rounded-full overflow-hidden">
                                <div class="h-full bg-blue-500 rounded-full" style="width: ${percent}%"></div>
                            </div>
                        </div>
                    </div>
                `);
            });
        }

        async function openVoucherModal() {
            const { value: v } = await Swal.fire({
                title: 'Buat Voucher Baru',
                confirmButtonColor: '#2563eb',
                html: `
                    <div class="text-left">
                        <label class="text-[10px] font-bold text-slate-400 uppercase">Kode Voucher</label>
                        <input id="v-code" class="swal2-input !mt-1 !text-sm" placeholder="CONTOH: HEMAT10">
                        <label class="text-[10px] font-bold text-slate-400 uppercase">Tipe Diskon</label>
                        <select id="v-type" class="swal2-input !mt-1 !text-sm"><option value="fixed">Rupiah (Rp)</option><option value="percentage">Persen (%)</option></select>
                        <label class="text-[10px] font-bold text-slate-400 uppercase">Nilai</label>
                        <input id="v-val" type="number" class="swal2-input !mt-1 !text-sm">
                        <div class="grid grid-cols-2 gap-3 mt-2">
                            <div><label class="text-[10px] font-bold text-slate-400 uppercase">Min. Belanja</label><input id="v-min" type="number" class="swal2-input !mt-1 !text-sm" value="0"></div>
                            <div><label class="text-[10px] font-bold text-slate-400 uppercase">Kuota (Redeem)</label><input id="v-quota" type="number" class="swal2-input !mt-1 !text-sm" value="10"></div>
                        </div>
                    </div>
                `,
                preConfirm: () => ({ 
                    code: $('#v-code').val().toUpperCase(), 
                    type: $('#v-type').val(), 
                    value: $('#v-val').val(), 
                    min_order: $('#v-min').val(), 
                    quota: $('#v-quota').val() 
                })
            });
            if(v) {
                await fetch('/api/admin/vouchers', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(v) });
                loadVouchers();
            }
        }

        async function deleteVoucher(id) {
            const confirm = await Swal.fire({ title: 'Hapus?', icon: 'warning', showCancelButton: true });
            if(confirm.isConfirmed) { await fetch(`/api/admin/vouchers/${id}`, { method: 'DELETE' }); loadVouchers(); }
        }

        $(document).ready(loadVouchers);
    </script>
</body>
</html>
