<!DOCTYPE html>
<html lang="id">
<head>
    <title>Admin - Dashboard Lana Store</title>
    <%- include('../partials/head') %>
    <style>
        .stat-card { background: white; border-radius: 20px; border: 1px solid #e2e8f0; padding: 24px; text-align: center; }
        .stat-card-sm { background: #eef2ff; border-radius: 16px; padding: 16px; border: 1px solid #e0e7ff; }
        .stat-label { color: #64748b; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; }
        .stat-value { font-size: 28px; font-weight: 800; color: #10b981; margin: 4px 0; }
        .stat-currency { font-size: 14px; font-weight: 700; color: #1e293b; }
    </style>
</head>
<body class="bg-slate-50 overflow-x-hidden">

    <%- include('../partials/sidebar') %>

    <div id="main-content" class="lg:ml-64 min-h-screen">
        <header class="h-16 bg-white border-b border-slate-200 sticky top-0 z-40 px-4 md:px-6 flex items-center justify-between">
            <div class="flex items-center gap-3">
                <button onclick="toggleSidebar()" class="lg:hidden w-10 h-10 flex items-center justify-center rounded-xl bg-slate-50 border text-slate-600">
                    <i class="fas fa-bars-staggered"></i>
                </button>
                <div>
                    <h1 class="font-bold text-slate-800 text-sm">Dashboard</h1>
                    <p class="text-[10px] text-slate-400 font-medium">Selamat Datang, Admin.</p>
                </div>
            </div>
            <div class="w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center text-blue-600 font-bold text-xs uppercase">A</div>
        </header>

        <main class="p-4 md:p-8 space-y-6">
            
            <!-- ROW 1: JUMLAH TRANSAKSI -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
                <div class="stat-card shadow-sm">
                    <p class="stat-label">Transaksi Kemarin</p>
                    <p class="stat-value"><%= stats.yesterday.count %></p>
                    <p class="text-[10px] font-bold text-slate-400 uppercase">Sukses</p>
                </div>
                <div class="stat-card shadow-sm border-blue-200">
                    <p class="stat-label">Transaksi Hari Ini</p>
                    <p class="stat-value text-blue-600"><%= stats.today.count %></p>
                    <p class="text-[10px] font-bold text-slate-400 uppercase">Sukses</p>
                </div>
                <div class="stat-card shadow-sm">
                    <p class="stat-label">Bulan Kemarin</p>
                    <p class="stat-value"><%= stats.lastMonth.count %></p>
                    <p class="text-[10px] font-bold text-slate-400 uppercase">Sukses</p>
                </div>
                <div class="stat-card shadow-sm">
                    <p class="stat-label">Bulan Ini</p>
                    <p class="stat-value"><%= stats.thisMonth.count %></p>
                    <p class="text-[10px] font-bold text-slate-400 uppercase">Sukses</p>
                </div>
            </div>

            <!-- ROW 2: OMSET & PROFIT -->
            <div class="bg-white rounded-[32px] border p-6 shadow-sm">
                <p class="text-xs font-black text-slate-800 uppercase mb-6 tracking-widest"><i class="fas fa-chart-line mr-2 text-blue-500"></i> Rekap Pendapatan</p>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
                    <div class="stat-card-sm">
                        <p class="text-[9px] font-black text-slate-400 uppercase">Omset Hari Ini</p>
                        <p class="stat-currency mt-1">Rp <%= stats.today.omset.toLocaleString() %></p>
                    </div>
                    <div class="stat-card-sm">
                        <p class="text-[9px] font-black text-slate-400 uppercase">Profit Hari Ini</p>
                        <p class="stat-currency text-blue-600 mt-1">Rp <%= stats.today.profit.toLocaleString() %></p>
                    </div>
                    <div class="stat-card-sm">
                        <p class="text-[9px] font-black text-slate-400 uppercase">Omset Bulan Ini</p>
                        <p class="stat-currency mt-1">Rp <%= stats.thisMonth.omset.toLocaleString() %></p>
                    </div>
                    <div class="stat-card-sm">
                        <p class="text-[9px] font-black text-slate-400 uppercase">Profit Bulan Ini</p>
                        <p class="stat-currency text-blue-600 mt-1">Rp <%= stats.thisMonth.profit.toLocaleString() %></p>
                    </div>
                </div>
            </div>

            <!-- ROW 3: PRODUK TERLARIS -->
            <div class="bg-white rounded-[32px] border p-6 shadow-sm">
                <p class="text-xs font-black text-slate-800 uppercase mb-6 tracking-widest"><i class="fas fa-trophy mr-2 text-yellow-500"></i> 10 Produk Terlaris</p>
                <div class="space-y-3">
                    <% topProducts.forEach((product, index) => { %>
                        <div class="flex items-center justify-between p-4 bg-slate-50 rounded-2xl border border-slate-100">
                            <div class="flex items-center gap-4">
                                <div class="w-8 h-8 rounded-lg bg-white border flex items-center justify-center font-black text-xs text-slate-400 shadow-sm">
                                    <%= index + 1 %>
                                </div>
                                <div>
                                    <p class="text-xs font-black text-slate-800 uppercase"><%= product._id %></p>
                                    <p class="text-[9px] text-slate-400 font-bold uppercase mt-1">Produk Layanan</p>
                                </div>
                            </div>
                            <span class="bg-blue-600 text-white px-3 py-1.5 rounded-lg text-[10px] font-black uppercase">Terjual : <%= product.total %></span>
                        </div>
                    <% }) %>
                </div>
            </div>

        </main>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.0.js"></script>
    <!-- Script Sidebar Anda -->
    <%- include('../partials/sidebar') %>
</body>
</html>
