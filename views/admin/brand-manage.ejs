<!DOCTYPE html>
<html lang="id">
<head>
    <title>Set Layanan - Brand></title>
    <%- include('../partials/head') %>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap');
        body { font-family: 'Plus Jakarta Sans', sans-serif; background-color: #f8fafc; }
        
        /* Table Android Style */
        .table-container { border-radius: 24px; background: white; padding: 15px; border: 1px solid #e2e8f0; }
        .table { font-size: 13px !important; }
        .img-icon { width: 28px; height: 28px; object-fit: contain; border-radius: 6px; }
        
        /* Checkbox Big Size for Touch */
        .form-check-input { width: 20px; height: 20px; cursor: pointer; border: 2px solid #cbd5e1; }
        .form-check-input:checked { background-color: #2563eb; border-color: #2563eb; }

        /* Floating Save Button Mobile */
        @media (max-width: 1023px) {
            .mobile-save-box {
                position: fixed; bottom: 20px; right: 20px; left: 20px; z-index: 50;
            }
        }
    </style>
</head>
<body class="overflow-x-hidden">

    <%- include('../partials/sidebar') %>

    <div id="main-content" class="lg:ml-64 min-h-screen">
        <!-- HEADER -->
        <header class="h-16 bg-white border-b border-slate-200 sticky top-0 z-40 px-4 md:px-6 flex items-center justify-between">
            <div class="flex items-center gap-3">
                <a href="/admin/brand" class="w-10 h-10 flex items-center justify-center rounded-xl bg-slate-50 border text-slate-600">
                    <i class="fas fa-arrow-left"></i>
                </a>
                <div>
                    <h1 class="font-bold text-slate-800 text-xs md:text-sm uppercase leading-none"><%= brand.name %></h1>
                    <p class="text-[9px] text-slate-400 font-bold uppercase mt-1">Pilih Produk Yang Dijual</p>
                </div>
            </div>
            
            <div class="hidden lg:block">
                <button onclick="saveChecklist()" id="btnSave" class="bg-blue-600 text-white px-6 py-2.5 rounded-2xl text-[11px] font-black uppercase shadow-lg shadow-blue-500/20 active:scale-95 transition-all">
                    Simpan (<span id="check-count">0</span>)
                </button>
            </div>
        </header>

        <main class="p-4 md:p-6">
            <!-- INFO BOX -->
            <div class="bg-blue-50 border border-blue-100 p-4 rounded-2xl mb-6 flex gap-3 items-center">
                <i class="fas fa-info-circle text-blue-500"></i>
                <p class="text-[11px] text-blue-700 font-bold uppercase leading-tight">
                    Cari layanan di kolom search, lalu centang produk yang ingin dimasukkan ke brand ini.
                </p>
            </div>

            <!-- TABLE CARD -->
            <div class="table-container shadow-sm overflow-hidden">
                <div class="table-responsive">
                    <table id="tableChecklist" class="table table-hover align-middle w-100">
                        <thead>
                            <tr class="text-[10px] font-black text-slate-400 uppercase">
                                <th width="40" class="text-center">PILIH</th>
                                <th>CODE</th>
                                <th>NAMA LAYANAN</th>
                                <th>KATEGORI</th>
                                <th>HARGA JUAL</th>
                                <th>API</th>
                            </tr>
                        </thead>
                        <tbody class="text-slate-600 font-semibold">
                            <!-- Render via DataTables Server-side -->
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Floating Save Button for Mobile -->
            <div class="mobile-save-box lg:hidden">
                <button onclick="saveChecklist()" id="btnSaveMob" class="w-full bg-blue-600 text-white py-4 rounded-2xl font-black uppercase shadow-2xl active:scale-95 transition-all">
                    Simpan Perubahan (<span class="count-val">0</span>)
                </button>
            </div>
        </main>
    </div>

    <!-- SCRIPTS -->
    <script src="https://code.jquery.com/jquery-3.7.0.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        const brandId = "<%= brand._id %>";
        
        // 1. Variabel Global untuk menyimpan pilihan (Persistent)
        // Kita ambil data awal dari database EJS
        let selectedServices = <%- JSON.stringify(brand.services || []) %>;

        $(document).ready(function() {
            updateCounter();

            const table = $('#tableChecklist').DataTable({
                "processing": true,
                "serverSide": true,
                "ajax": {
                    "url": "/api/admin/services", // Menggunakan API yang sama dengan Kelola Layanan
                    "type": "GET"
                },
                "pageLength": 20,
                "lengthMenu": [[10, 20, 50, 100], [10, 20, 50, 100]],
                "columns": [
                    { 
                        "data": null,
                        "className": "text-center",
                        "orderable": false,
                        "render": function(data) {
                            const isChecked = selectedServices.includes(data.service_id) ? 'checked' : '';
                            return `<input type="checkbox" class="form-check-input service-checkbox" 
                                        data-id="${data.service_id}" ${isChecked} 
                                        onchange="toggleItem('${data.service_id}', this)">`;
                        }
                    },
                    { "data": "service_id" },
                    { 
                        "data": null, 
                        "render": d => `
                            <div class="flex items-center gap-2">
                                <img src="${d.img_url}" class="img-icon">
                                <div class="flex flex-col">
                                    <span class="text-slate-800 leading-tight">${d.name}</span>
                                    <span class="text-[9px] text-slate-400 uppercase">${d.brand}</span>
                                </div>
                            </div>` 
                    },
                    { "data": "category" },
                    { 
                        "data": "price_sell", 
                        "render": d => `<span class="text-blue-600 font-black">Rp ${parseInt(d).toLocaleString()}</span>` 
                    },
                    { 
                        "data": "status_api", 
                        "render": d => {
                            let color = d === 'available' ? 'bg-green-100 text-green-600' : 'bg-red-100 text-red-600';
                            return `<span class="px-2 py-0.5 rounded text-[9px] font-black uppercase ${color}">${d}</span>`;
                        }
                    }
                ],
                "language": {
                    "search": "",
                    "searchPlaceholder": "Cari produk (Contoh: Mobile Legends)...",
                    "processing": "<div class='spinner-border text-primary' role='status'></div>"
                }
            });
        });

        // 2. Fungsi untuk menambah/menghapus ID dari list pilihan
        function toggleItem(serviceId, checkbox) {
            if (checkbox.checked) {
                if (!selectedServices.includes(serviceId)) {
                    selectedServices.push(serviceId);
                }
            } else {
                selectedServices = selectedServices.filter(id => id !== serviceId);
            }
            updateCounter();
        }

        // 3. Update Angka di tombol simpan
        function updateCounter() {
            const count = selectedServices.length;
            $('#check-count').text(count);
            $('.count-val').text(count);
        }

        // 4. Kirim daftar ID yang dipilih ke Backend
        async function saveChecklist() {
            const btn = $('#btnSave, #btnSaveMob');
            btn.attr('disabled', true).text('Processing...');

            try {
                const res = await fetch(`/api/admin/brands/${brandId}/services`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ services: selectedServices })
                });
                
                const data = await res.json();
                if(data.status) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Berhasil Disimpan',
                        text: `Sebanyak ${selectedServices.length} layanan dikaitkan ke brand ini.`,
                        timer: 2000,
                        showConfirmButton: false
                    });
                }
            } catch (e) {
                Swal.fire('Error', 'Gagal menghubungi server', 'error');
            } finally {
                btn.attr('disabled', false);
                updateCounter();
                $('#btnSave').html(`Simpan (<span id="check-count">${selectedServices.length}</span>)`);
                $('#btnSaveMob').html(`Simpan Perubahan (<span class="count-val">${selectedServices.length}</span>)`);
            }
        }
    </script>

</body>
</html>
