<!DOCTYPE html>
<html lang="id">
<head>
    <title>Admin - Kelola Brand & Game</title>
    <%- include('../partials/head') %>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap');
        body { font-family: 'Plus Jakarta Sans', sans-serif; background-color: #f8fafc; }
        
        /* Android UI Card Style */
        .brand-card {
            background: white;
            border: 1px solid #e2e8f0;
            border-radius: 28px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .brand-card:hover {
            border-color: #3b82f6;
            box-shadow: 0 20px 25px -5px rgba(59, 130, 246, 0.1);
            transform: translateY(-5px);
        }
        
        .status-badge {
            padding: 4px 12px;
            border-radius: 10px;
            font-size: 10px;
            font-weight: 800;
            text-transform: uppercase;
        }

        /* Custom Swal Input Style */
        .swal-input-label {
            font-size: 11px;
            font-weight: 800;
            color: #64748b;
            text-transform: uppercase;
            margin-bottom: 4px;
            display: block;
            margin-top: 12px;
        }
    </style>
</head>
<body class="overflow-x-hidden">

    <%- include('../partials/sidebar') %>

    <div id="main-content" class="lg:ml-64 min-h-screen">
        <!-- HEADER -->
        <header class="h-16 bg-white border-b border-slate-200 sticky top-0 z-40 px-4 md:px-6 flex items-center justify-between">
            <div class="flex items-center gap-3">
                <button onclick="toggleSidebar()" class="lg:hidden w-10 h-10 flex items-center justify-center rounded-xl bg-slate-50 border text-slate-600">
                    <i class="fas fa-bars-staggered"></i>
                </button>
                <h1 class="font-bold text-slate-800 text-sm md:text-base">Kelola Brand Game</h1>
            </div>
            <button onclick="openBrandModal()" class="bg-blue-600 text-white px-5 py-2.5 rounded-2xl text-[11px] font-black uppercase shadow-lg shadow-blue-500/20 active:scale-95 transition-all">
                <i class="fas fa-plus mr-1"></i> Tambah Brand
            </button>
        </header>

        <!-- MAIN CONTENT -->
        <main class="p-4 md:p-8">
            
            <div id="brand-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                <!-- Data Brand ditarik via AJAX -->
                <div class="col-span-full py-20 text-center">
                    <div class="animate-spin h-8 w-8 border-4 border-blue-500 border-t-transparent rounded-full mx-auto mb-4"></div>
                    <p class="text-slate-400 font-bold uppercase text-xs tracking-widest">Memuat Brand...</p>
                </div>
            </div>

        </main>
    </div>

    <!-- SCRIPTS -->
    <script src="https://code.jquery.com/jquery-3.7.0.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        // 1. Ambil data Brand dari database
        async function loadBrands() {
            try {
                const res = await fetch('/api/admin/brands');
                const json = await res.json();
                const grid = $('#brand-grid').empty();

                if(json.data.length === 0) {
                    grid.html('<div class="col-span-full py-20 text-center text-slate-400 font-bold uppercase text-xs">Belum ada brand. Klik Tambah Brand.</div>');
                    return;
                }

                json.data.forEach(b => {
                    const statusClass = b.status === 'active' ? 'bg-green-100 text-green-600' : 'bg-red-100 text-red-600';
                    grid.append(`
                        <div class="brand-card p-6 flex flex-col items-center text-center relative overflow-hidden">
                            <div class="absolute top-4 right-4">
                                <span class="status-badge ${statusClass}">${b.status}</span>
                            </div>
                            
                            <img src="${b.icon_url}" class="w-20 h-20 rounded-[24px] object-cover mb-4 shadow-xl border-4 border-white">
                            
                            <h3 class="font-black text-slate-800 text-sm uppercase leading-tight mb-1">${b.name}</h3>
                            <p class="text-[10px] text-slate-400 font-bold uppercase mb-4 tracking-tighter">${b.category}</p>
                            
                            <div class="bg-slate-50 w-full py-2 rounded-xl mb-6 border border-slate-100">
                                <p class="text-[9px] text-slate-400 font-bold uppercase leading-none">URL Slug</p>
                                <p class="text-[11px] text-blue-600 font-black mt-1">/id/${b.slug}</p>
                            </div>

                            <div class="flex gap-2 w-full">
                                <a href="/admin/brand/services/${b._id}" class="flex-1 bg-blue-600 text-white py-3 rounded-2xl text-[10px] font-black uppercase no-underline shadow-lg shadow-blue-500/20 active:scale-95 transition-all">
                                    <i class="fas fa-list-ul mr-1"></i> Atur Layanan
                                </a>
                                <button onclick="deleteBrand('${b._id}')" class="w-12 bg-red-50 text-red-500 py-3 rounded-2xl text-[10px] font-bold active:scale-95 transition-all">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </div>
                    `);
                });
            } catch (e) {
                console.error("Gagal load brand");
            }
        }

        // 2. Modal Tambah Brand dengan Config Form Dinamis
        async function openBrandModal() {
            const { value: f } = await Swal.fire({
                title: '<span class="text-sm font-black uppercase tracking-widest text-slate-800">Tambah Brand Game</span>',
                width: '550px',
                confirmButtonText: 'SIMPAN BRAND',
                confirmButtonColor: '#2563eb',
                showCancelButton: true,
                cancelButtonText: 'BATAL',
                html: `
                    <div class="text-left px-2">
                        <label class="swal-input-label">Nama Game / Brand</label>
                        <input id="n-name" class="swal2-input !mt-0 !text-sm" placeholder="Contoh: Free Fire" 
                            onkeyup="document.getElementById('n-slug').value = this.value.toLowerCase().replace(/[^a-z0-9]/g, '-')">
                        
                        <label class="swal-input-label">Slug URL (Otomatis)</label>
                        <input id="n-slug" class="swal2-input !mt-0 !text-sm !bg-slate-50" readonly>

                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="swal-input-label">Kategori</label>
                                <select id="n-cat" class="swal2-input !mt-0 !text-sm">
                                    <option value="Games">Games</option>
                                    <option value="Pulsa">Pulsa / Data</option>
                                    <option value="E-Wallet">E-Wallet</option>
                                    <option value="Voucher">Voucher Digital</option>
                                </select>
                            </div>
                            <div>
                                <label class="swal-input-label">Status</label>
                                <select id="n-status" class="swal2-input !mt-0 !text-sm">
                                    <option value="active">Aktif (Tampil)</option>
                                    <option value="inactive">Nonaktif</option>
                                </select>
                            </div>
                        </div>

                        <label class="swal-input-label">URL Icon Brand</label>
                        <input id="n-icon" class="swal2-input !mt-0 !text-sm" placeholder="https://link-gambar.com/icon.png">

                        <!-- FORMAT FORM CONFIG (SESUAI FOTO) -->
                        <div class="mt-6 p-5 bg-slate-50 rounded-[24px] border border-slate-100">
                            <p class="text-[10px] font-black text-slate-800 uppercase mb-4 flex items-center gap-2">
                                <i class="fas fa-file-invoice text-blue-500"></i> Format Form Input User
                            </p>
                            
                            <div class="grid grid-cols-2 gap-3 mb-4">
                                <div>
                                    <label class="text-[9px] font-bold text-slate-400 uppercase">Label Input 1</label>
                                    <input id="f-t-label" class="swal2-input !mt-1 !text-xs !h-10 !m-0 !w-full" value="User ID">
                                </div>
                                <div>
                                    <label class="text-[9px] font-bold text-slate-400 uppercase">Tipe Input</label>
                                    <select id="f-t-type" class="swal2-input !mt-1 !text-xs !h-10 !m-0 !w-full">
                                        <option value="text">Text</option>
                                        <option value="number">Nomor (Angka)</option>
                                        <option value="email">Email</option>
                                    </select>
                                </div>
                            </div>

                            <div class="flex items-center gap-2 mb-4">
                                <input type="checkbox" id="f-has-server" class="w-4 h-4" onchange="$('#server-config').toggleClass('hidden')">
                                <label for="f-has-server" class="text-[10px] font-bold text-slate-600 uppercase cursor-pointer">Gunakan Input Ke-2 (Server ID)</label>
                            </div>

                            <div id="server-config" class="hidden grid grid-cols-2 gap-3 animate-fade-in">
                                <div>
                                    <label class="text-[9px] font-bold text-slate-400 uppercase">Label Input 2</label>
                                    <input id="f-s-label" class="swal2-input !mt-1 !text-xs !h-10 !m-0 !w-full" placeholder="Contoh: Server">
                                </div>
                                <div>
                                    <label class="text-[9px] font-bold text-slate-400 uppercase">Tipe Input 2</label>
                                    <select id="f-s-type" class="swal2-input !mt-1 !text-xs !h-10 !m-0 !w-full">
                                        <option value="text">Text</option>
                                        <option value="number">Nomor</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>
                `,
                preConfirm: () => {
                    const name = $('#n-name').val();
                    const slug = $('#n-slug').val();
                    const icon = $('#n-icon').val();
                    if(!name || !slug || !icon) return Swal.showValidationMessage('Nama, Slug, dan Icon wajib diisi!');
                    
                    return {
                        name: name,
                        slug: slug,
                        category: $('#n-cat').val(),
                        status: $('#n-status').val(),
                        icon_url: icon,
                        form_config: {
                            target_label: $('#f-t-label').val(),
                            target_type: $('#f-t-type').val(),
                            has_server: $('#f-has-server').is(':checked'),
                            server_label: $('#f-s-label').val(),
                            server_type: $('#f-s-type').val()
                        }
                    }
                }
            });

            if (f) {
                try {
                    const res = await fetch('/api/admin/brands', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(f)
                    });
                    const result = await res.json();
                    if(result.status) {
                        Swal.fire('Berhasil!', 'Brand baru telah dibuat.', 'success');
                        loadBrands();
                    } else {
                        Swal.fire('Gagal!', result.message, 'error');
                    }
                } catch (e) { Swal.fire('Error', 'Server tidak merespon', 'error'); }
            }
        }

        // 3. Hapus Brand
        async function deleteBrand(id) {
            const ask = await Swal.fire({
                title: 'Hapus Brand?',
                text: "Semua konfigurasi form dan link layanan akan hilang!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                confirmButtonText: 'YA, HAPUS'
            });

            if (ask.isConfirmed) {
                const res = await fetch(`/api/admin/brands/${id}`, { method: 'DELETE' });
                const json = await res.json();
                if(json.status) loadBrands();
            }
        }

        $(document).ready(loadBrands);
    </script>
</body>
</html>
