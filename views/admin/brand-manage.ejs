<!DOCTYPE html>
<html lang="id">
<head>
    <title>Admin - Kelola Brand</title>
    <%- include('../partials/head') %>
    <style>
        .brand-card { background: white; border: 1px solid #e2e8f0; border-radius: 28px; transition: all 0.3s; }
        #sidebar { transition: transform 0.3s ease-in-out; }
    </style>
</head>
<body class="bg-slate-50 overflow-x-hidden">

    <%- include('../partials/sidebar') %>

    <div id="main-content" class="lg:ml-64 min-h-screen">
        <!-- HEADER DENGAN HAMBURGER -->
        <header class="h-16 bg-white border-b border-slate-200 sticky top-0 z-40 px-4 flex items-center justify-between">
            <div class="flex items-center gap-3">
                <button onclick="toggleSidebar()" class="lg:hidden w-10 h-10 flex items-center justify-center rounded-xl bg-slate-50 text-slate-600 border active:scale-95 transition-all">
                    <i class="fas fa-bars-staggered"></i>
                </button>
                <h1 class="font-bold text-slate-800 text-sm uppercase">Management Brand</h1>
            </div>
            <button onclick="openBrandModal()" class="bg-blue-600 text-white px-4 py-2 rounded-xl text-[10px] font-black uppercase shadow-lg active:scale-95">
                <i class="fas fa-plus mr-1"></i> Brand
            </button>
        </header>

        <main class="p-4 md:p-8">
            <div id="brand-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6"></div>
        </main>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.0.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        async function loadBrands() {
            const res = await fetch('/api/admin/brands');
            const json = await res.json();
            const grid = $('#brand-grid').empty();
            json.data.forEach(b => {
                grid.append(`
                    <div class="brand-card p-6 flex flex-col items-center text-center shadow-sm">
                        <img src="${b.icon_url}" class="w-20 h-20 rounded-[24px] object-cover mb-4 shadow-lg border">
                        <h3 class="font-black text-slate-800 text-sm uppercase mb-1">${b.name}</h3>
                        
                        <div class="flex items-center gap-2 mb-4 bg-slate-50 p-2 rounded-xl border w-full justify-between">
                            <span class="text-[9px] font-black text-slate-500 uppercase">Populer</span>
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" onchange="togglePopular('${b._id}', this.checked)" ${b.is_popular ? 'checked' : ''}>
                            </div>
                        </div>

                        <div class="flex gap-2 w-full">
                            <a href="/admin/brand/services/${b._id}" class="flex-1 bg-blue-600 text-white py-2.5 rounded-xl text-[10px] font-black uppercase no-underline text-center">Layanan</a>
                            <button onclick="deleteBrand('${b._id}')" class="w-10 bg-red-50 text-red-500 py-2.5 rounded-xl text-[10px]"><i class="fas fa-trash"></i></button>
                        </div>
                    </div>
                `);
            });
        }
        async function togglePopular(id, status) {
            await fetch(`/api/admin/brands/popular/${id}`, { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ is_popular: status }) });
        }
        async function openBrandModal() {
            const { value: f } = await Swal.fire({
                title: 'Tambah Brand',
                html: `<input id="n-name" class="swal2-input" placeholder="Nama Game"><input id="n-icon" class="swal2-input" placeholder="URL Icon"><select id="n-cat" class="swal2-input"><option value="Games">Games</option><option value="Pulsa">Pulsa</option></select>`,
                preConfirm: () => ({ name: $('#n-name').val(), slug: $('#n-name').val().toLowerCase().replace(/ /g, '-'), icon_url: $('#n-icon').val(), category: $('#n-cat').val() })
            });
            if(f) { await fetch('/api/admin/brands', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify(f) }); loadBrands(); }
        }
        async function deleteBrand(id) { if(confirm("Hapus Brand?")) { await fetch(`/api/admin/brands/${id}`, { method: 'DELETE' }); loadBrands(); } }
        $(document).ready(loadBrands);
    </script>
</body>
</html>
