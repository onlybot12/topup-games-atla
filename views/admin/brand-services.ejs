<!DOCTYPE html>
<html lang="id">
<head>
    <title>Set Layanan ></title>
    <%- include('../partials/head') %>
    <style>
        .service-row { transition: all 0.2s; border-radius: 12px; margin-bottom: 8px; border: 1px solid #e2e8f0; background: white; }
        .service-row:hover { border-color: #3b82f6; }
        .check-custom { width: 20px; height: 20px; border-radius: 6px; cursor: pointer; }
    </style>
</head>
<body class="overflow-x-hidden">

    <%- include('../partials/sidebar') %>

    <div id="main-content" class="lg:ml-64 min-h-screen">
        <header class="h-16 bg-white border-b px-4 flex items-center justify-between sticky top-0 z-40">
            <div class="flex items-center gap-3">
                <a href="/admin/brand" class="w-8 h-8 flex items-center justify-center rounded-lg bg-slate-100 text-slate-600"><i class="fas fa-arrow-left text-xs"></i></a>
                <div>
                    <h1 class="font-black text-slate-800 text-xs uppercase leading-none"><%= brand.name %></h1>
                    <p class="text-[9px] text-slate-400 font-bold uppercase mt-1">Pilih Produk Layanan</p>
                </div>
            </div>
            <button onclick="saveChecklist()" id="btnSave" class="bg-blue-600 text-white px-6 py-2 rounded-xl text-[10px] font-black uppercase shadow-lg shadow-blue-500/20">
                Simpan (<span id="check-count">0</span>)
            </button>
        </header>

        <main class="p-4 md:p-6">
            <!-- Search Filter -->
            <div class="bg-white p-4 rounded-2xl border border-slate-200 mb-6 shadow-sm">
                <div class="relative">
                    <i class="fas fa-search absolute left-4 top-1/2 -translate-y-1/2 text-slate-400"></i>
                    <input type="text" id="searchService" onkeyup="filterServices()" placeholder="Cari ID atau Nama Layanan (Contoh: Free Fire)..." 
                        class="w-full pl-11 pr-4 py-3 bg-slate-50 border-none rounded-xl text-sm focus:ring-2 focus:ring-blue-500 outline-none">
                </div>
            </div>

            <!-- List Checklist -->
            <div id="services-container" class="space-y-2">
                <div class="text-center py-20 text-slate-400 font-bold">Memuat data layanan...</div>
            </div>
        </main>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.0.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        const brandId = "<%= brand._id %>";
        let allServices = [];
        let selectedServices = <%- JSON.stringify(brand.services || []) %>; // Mengambil data yang sudah tercentang sebelumnya

        async function loadServices() {
            const res = await fetch('/api/admin/all-services');
            const json = await res.json();
            allServices = json.data;
            renderServices();
            updateCounter();
        }

        function renderServices() {
            const container = $('#services-container').empty();
            const search = $('#searchService').val().toLowerCase();

            const filtered = allServices.filter(s => 
                s.name.toLowerCase().includes(search) || 
                s.service_id.toLowerCase().includes(search) ||
                s.brand.toLowerCase().includes(search)
            );

            if(filtered.length === 0) {
                container.html('<div class="text-center py-20 text-slate-400 font-bold uppercase text-xs">Layanan tidak ditemukan</div>');
                return;
            }

            filtered.forEach(s => {
                const isChecked = selectedServices.includes(s.service_id) ? 'checked' : '';
                container.append(`
                    <label class="service-row p-4 flex items-center justify-between cursor-pointer active:scale-[0.98] transition-all">
                        <div class="flex items-center gap-4">
                            <input type="checkbox" class="check-custom form-check-input mt-0" 
                                value="${s.service_id}" ${isChecked} onchange="handleCheck(this)">
                            <div>
                                <p class="text-xs font-black text-slate-800 leading-none uppercase">${s.name}</p>
                                <p class="text-[9px] text-slate-400 font-bold mt-1 uppercase">${s.brand} | ID: ${s.service_id} | Rp ${s.price_sell.toLocaleString()}</p>
                            </div>
                        </div>
                        <i class="fas fa-check-circle text-blue-500 text-sm ${isChecked ? '' : 'hidden'}"></i>
                    </label>
                `);
            });
        }

        function handleCheck(el) {
            const id = el.value;
            if(el.checked) {
                if(!selectedServices.includes(id)) selectedServices.push(id);
            } else {
                selectedServices = selectedServices.filter(item => item !== id);
            }
            updateCounter();
            // Toggle icon centang di sebelah kanan
            $(el).closest('label').find('i').toggleClass('hidden', !el.checked);
        }

        function updateCounter() {
            $('#check-count').text(selectedServices.length);
        }

        function filterServices() { renderServices(); }

        async function saveChecklist() {
            const btn = $('#btnSave');
            btn.attr('disabled', true).text('Menyimpan...');

            try {
                const res = await fetch(`/api/admin/brands/${brandId}/services`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ services: selectedServices })
                });
                const data = await res.json();
                if(data.status) {
                    Swal.fire({ icon: 'success', title: 'Berhasil!', text: data.message, timer: 2000, showConfirmButton: false });
                }
            } catch (e) {
                Swal.fire('Error', 'Gagal menyimpan', 'error');
            } finally {
                btn.attr('disabled', false).html(`Simpan (<span id="check-count">${selectedServices.length}</span>)`);
            }
        }

        $(document).ready(loadServices);
    </script>
</body>
</html>
