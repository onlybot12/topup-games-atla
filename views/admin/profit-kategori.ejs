<!DOCTYPE html>
<html lang="id">
<head>
    <title>Admin - Smart Markup</title>
    <%- include('../partials/head') %>
</head>
<body class="bg-slate-50 overflow-x-hidden">
    <%- include('../partials/sidebar') %>
    <div id="main-content" class="lg:ml-64 min-h-screen">
        <header class="h-16 bg-white border-b px-4 flex items-center justify-between sticky top-0 z-40">
            <div class="flex items-center gap-3">
                <button onclick="toggleSidebar()" class="lg:hidden w-10 h-10 flex items-center justify-center rounded-xl bg-slate-50 border text-slate-600">
                    <i class="fas fa-bars-staggered"></i>
                </button>
                <h1 class="font-bold text-slate-800 text-sm">Smart Markup Kategori</h1>
            </div>
        </header>

        <main class="p-4 md:p-8">
            <div class="bg-blue-600 rounded-[28px] p-6 text-white mb-8 shadow-xl shadow-blue-200">
                <h2 class="font-black text-lg mb-1 uppercase italic">Atur Cuan Per Produk</h2>
                <p class="text-[10px] font-bold opacity-80 uppercase tracking-widest">Set profit berbeda untuk tiap kategori agar harga kompetitif.</p>
            </div>

            <div id="category-list" class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <!-- Data Kategori render disini -->
            </div>
        </main>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.0.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        async function loadSettings() {
            // Ambil kategori unik dari database layanan
            const catRes = await fetch('/api/admin/get-unique-categories');
            const catJson = await catRes.json();
            
            // Ambil settingan profit yang sudah ada
            const profRes = await fetch('/api/admin/category-profits');
            const profJson = await profRes.json();
            
            const profitMap = {};
            profJson.data.forEach(p => { profitMap[p.category_name] = p; });

            const grid = $('#category-list').empty();
            catJson.data.forEach(cat => {
                const set = profitMap[cat] || { type: 'percentage', value: 5 };
                grid.append(`
                    <div class="bg-white border p-5 rounded-[24px] shadow-sm flex items-center justify-between">
                        <div>
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-tighter mb-1">Kategori</p>
                            <h3 class="font-black text-slate-800 text-sm uppercase">${cat}</h3>
                            <p class="text-[11px] font-bold text-blue-600 mt-2">
                                Profit: ${set.value} ${set.type === 'percentage' ? '%' : 'Rp'}
                            </p>
                        </div>
                        <button onclick="editProfit('${cat}', '${set.type}', ${set.value})" class="w-10 h-10 bg-slate-900 text-white rounded-xl active:scale-90 transition-all">
                            <i class="fas fa-pen text-xs"></i>
                        </button>
                    </div>
                `);
            });
        }

        async function editProfit(name, type, val) {
            const { value: form } = await Swal.fire({
                title: 'Set Profit: ' + name,
                html: `
                    <div class="text-left">
                        <label class="text-[10px] font-bold text-slate-400 uppercase">Tipe Profit</label>
                        <select id="sw-type" class="swal2-input !mt-1">
                            <option value="percentage" ${type==='percentage'?'selected':''}>Persentase (%)</option>
                            <option value="fixed" ${type==='fixed'?'selected':''}>Rupiah (Rp)</option>
                        </select>
                        <label class="text-[10px] font-bold text-slate-400 uppercase mt-3 block">Nilai Profit</label>
                        <input id="sw-val" type="number" class="swal2-input !mt-1" value="${val}">
                    </div>
                `,
                preConfirm: () => ({ category_name: name, type: $('#sw-type').val(), value: $('#sw-val').val() })
            });

            if(form) {
                await fetch('/api/admin/category-profits', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(form)
                });
                loadSettings();
                Swal.fire({ icon: 'success', title: 'Tersimpan', showConfirmButton: false, timer: 1000 });
            }
        }

        $(document).ready(loadSettings);
    </script>
</body>
</html>
