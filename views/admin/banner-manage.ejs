<!DOCTYPE html>
<html lang="id">
<head>
    <title>Admin - Kelola Banner</title>
    <%- include('../partials/head') %>
</head>
<body class="bg-slate-50">
    <%- include('../partials/sidebar') %>
    <div id="main-content" class="lg:ml-64 min-h-screen">
        <header class="h-16 bg-white border-b px-6 flex items-center justify-between sticky top-0 z-40">
            <h1 class="font-bold text-slate-800">Slider Banner Promo</h1>
            <button onclick="addBanner()" class="bg-blue-600 text-white px-4 py-2 rounded-xl text-xs font-bold uppercase shadow-lg shadow-blue-500/20">
                <i class="fas fa-plus mr-1"></i> Tambah Banner
            </button>
        </header>

        <main class="p-6">
            <div id="banner-grid" class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Data Banner -->
            </div>
        </main>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.0.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        async function loadBanners() {
            const res = await fetch('/api/admin/banners');
            const json = await res.json();
            const grid = $('#banner-grid').empty();
            json.data.forEach(b => {
                grid.append(`
                    <div class="bg-white p-3 rounded-3xl border shadow-sm">
                        <img src="${b.image_url}" class="w-full aspect-[21/9] object-cover rounded-2xl mb-3">
                        <div class="flex justify-between items-center px-2">
                            <span class="text-[10px] text-slate-400 font-bold truncate max-w-[200px]">${b.target_link}</span>
                            <button onclick="deleteBanner('${b._id}')" class="text-red-500 text-sm"><i class="fas fa-trash"></i></button>
                        </div>
                    </div>
                `);
            });
        }

        async function addBanner() {
            const { value: f } = await Swal.fire({
                title: 'Tambah Banner',
                html: `
                    <input id="b-img" class="swal2-input" placeholder="URL Gambar (21:9)">
                    <input id="b-link" class="swal2-input" placeholder="Link Tujuan (/id/free-fire)">
                `,
                preConfirm: () => ({ image_url: $('#b-img').val(), target_link: $('#b-link').val() })
            });
            if(f) {
                await fetch('/api/admin/banners', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify(f) });
                loadBanners();
            }
        }

        async function deleteBanner(id) {
            await fetch(`/api/admin/banners/${id}`, { method: 'DELETE' });
            loadBanners();
        }

        $(document).ready(loadBanners);
    </script>
</body>
</html>
