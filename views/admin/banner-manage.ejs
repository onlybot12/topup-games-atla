<!DOCTYPE html>
<html lang="id">
<head>
    <title>Admin - Kelola Banner</title>
    <%- include('../partials/head') %>
</head>
<body class="bg-slate-50 overflow-x-hidden">
    <%- include('../partials/sidebar') %>
    <div id="main-content" class="lg:ml-64 min-h-screen">
        <!-- HEADER DENGAN HAMBURGER -->
        <header class="h-16 bg-white border-b border-slate-200 sticky top-0 z-40 px-4 flex items-center justify-between">
            <div class="flex items-center gap-3">
                <button onclick="toggleSidebar()" class="lg:hidden w-10 h-10 flex items-center justify-center rounded-xl bg-slate-50 border text-slate-600 active:scale-95 transition-all">
                    <i class="fas fa-bars-staggered"></i>
                </button>
                <h1 class="font-bold text-slate-800 text-sm uppercase">Banner Promo</h1>
            </div>
            <button onclick="addBanner()" class="bg-blue-600 text-white px-4 py-2 rounded-xl text-[10px] font-black uppercase shadow-lg">
                <i class="fas fa-plus mr-1"></i> Tambah
            </button>
        </header>

        <main class="p-4 md:p-6">
            <div id="banner-grid" class="grid grid-cols-1 md:grid-cols-2 gap-6"></div>
        </main>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.0.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        async function loadBanners() {
            const res = await fetch('/api/admin/banners');
            const json = await res.json();
            const grid = $('#banner-grid').empty();
            json.data.forEach(b => {
                grid.append(`
                    <div class="bg-white p-3 rounded-3xl border shadow-sm">
                        <img src="${b.image_url}" class="w-full aspect-[21/9] object-cover rounded-2xl mb-3 border">
                        <div class="flex justify-between items-center px-2">
                            <span class="text-[9px] text-slate-400 font-bold truncate max-w-[150px]">${b.target_link}</span>
                            <button onclick="deleteBanner('${b._id}')" class="text-red-500"><i class="fas fa-trash"></i></button>
                        </div>
                    </div>
                `);
            });
        }
        async function addBanner() {
            const { value: f } = await Swal.fire({
                title: 'Tambah Banner',
                html: `<input id="b-img" class="swal2-input" placeholder="URL Gambar"><input id="b-link" class="swal2-input" placeholder="Link (/id/free-fire)">`,
                preConfirm: () => ({ image_url: $('#b-img').val(), target_link: $('#b-link').val() })
            });
            if(f) { await fetch('/api/admin/banners', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify(f) }); loadBanners(); }
        }
        async function deleteBanner(id) { await fetch(`/api/admin/banners/${id}`, { method: 'DELETE' }); loadBanners(); }
        $(document).ready(loadBanners);
    </script>
</body>
</html>
