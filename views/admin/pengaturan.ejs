<!DOCTYPE html>
<html lang="id">
<head>
    <title>Admin - Pengaturan Sistem</title>
    <%- include('../partials/head') %>
    <style>
        .config-card { 
            background: white; 
            border: 1px solid #e2e8f0; 
            border-radius: 32px; 
            padding: 24px; 
            margin-bottom: 20px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        }
        .input-label {
            font-size: 10px;
            font-weight: 800;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            margin-bottom: 8px;
            display: block;
        }
        .custom-input {
            width: 100%;
            background-color: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 16px;
            padding: 12px 16px;
            font-size: 14px;
            font-weight: 700;
            color: #1e293b;
            outline: none;
            transition: all 0.2s;
        }
        .custom-input:focus {
            border-color: #3b82f6;
            background-color: white;
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
        }
        textarea.custom-input { min-height: 80px; resize: none; }
    </style>
</head>
<body class="bg-slate-50 overflow-x-hidden">

    <%- include('../partials/sidebar') %>

    <div id="main-content" class="lg:ml-64 min-h-screen">
        <!-- HEADER DENGAN HAMBURGER -->
        <header class="h-16 bg-white border-b border-slate-200 sticky top-0 z-40 px-4 flex items-center justify-between">
            <div class="flex items-center gap-3">
                <button onclick="toggleSidebar()" class="lg:hidden w-10 h-10 flex items-center justify-center rounded-xl bg-slate-50 border text-slate-600 active:scale-95 transition-all">
                    <i class="fas fa-bars-staggered"></i>
                </button>
                <h1 class="font-bold text-slate-800 text-sm uppercase tracking-tight">Pengaturan</h1>
            </div>
            <button onclick="saveSettings()" id="btnSave" class="bg-blue-600 text-white px-6 py-2 rounded-xl text-[11px] font-black uppercase shadow-lg shadow-blue-500/20 active:scale-95 transition-all">
                Simpan
            </button>
        </header>

        <main class="p-4 md:p-8 max-w-4xl mx-auto">
            
            <!-- SECTION 1: SEO & BRANDING -->
            <div class="config-card">
                <p class="text-blue-600 font-black text-[11px] uppercase mb-6 tracking-widest flex items-center gap-2">
                    <i class="fas fa-search"></i> SEO & Branding (Google Search)
                </p>
                <div class="space-y-4">
                    <div>
                        <label class="input-label">Nama Toko (Judul Web)</label>
                        <input type="text" id="shop_name" class="custom-input" placeholder="Contoh: Lana Store">
                    </div>
                    <div>
                        <label class="input-label">Meta Deskripsi (Ringkasan di Google)</label>
                        <textarea id="meta_description" class="custom-input" placeholder="Topup Game Tercepat & Termurah di Indonesia..."></textarea>
                    </div>
                    <div>
                        <label class="input-label">Keywords (Pisahkan dengan koma)</label>
                        <input type="text" id="meta_keywords" class="custom-input" placeholder="topup ml, ff murah, diamond ml">
                    </div>
                    <div>
                        <label class="input-label">URL Logo Toko (Icon Share)</label>
                        <input type="text" id="logo_url" class="custom-input" placeholder="https://link-gambar-logo.png">
                    </div>
                </div>
            </div>

            <!-- SECTION 2: BIAYA & PAJAK -->
            <div class="config-card">
                <p class="text-blue-600 font-black text-[11px] uppercase mb-6 tracking-widest flex items-center gap-2">
                    <i class="fas fa-wallet"></i> Biaya Transaksi QRIS
                </p>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="input-label">Admin Fee (Tetap Rp)</label>
                        <div class="relative">
                            <span class="absolute left-4 top-1/2 -translate-y-1/2 font-bold text-slate-400 text-sm">Rp</span>
                            <input type="number" id="admin_fee" class="custom-input !pl-12" placeholder="700">
                        </div>
                    </div>
                    <div>
                        <label class="input-label">Pajak MDR Atlantic (%)</label>
                        <div class="relative">
                            <input type="number" id="tax_percent" step="0.1" class="custom-input !pr-10" placeholder="1.4">
                            <span class="absolute right-4 top-1/2 -translate-y-1/2 font-bold text-slate-400 text-sm">%</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- SECTION 3: FOOTER BRANDING (NEW) -->
            <div class="config-card">
                <p class="text-blue-600 font-black text-[11px] uppercase mb-6 tracking-widest flex items-center gap-2">
                    <i class="fas fa-shoe-prints"></i> Footer Branding & Legalitas
                </p>
                <div class="space-y-4">
                    <div>
                        <label class="input-label">Tagline Footer (Deskripsi singkat di bawah logo)</label>
                        <textarea id="footer_description" class="custom-input" placeholder="No #1 supplier top up game & voucher terlaris..."></textarea>
                    </div>
                    <div>
                        <label class="input-label">Info Kementerian (Perlindungan Konsumen)</label>
                        <input type="text" id="footer_trade_info" class="custom-input" placeholder="Direktorat Jenderal Perlindungan Konsumen...">
                    </div>
                </div>
            </div>

            <!-- SECTION 4: TEKS HALAMAN DEPAN -->
            <div class="config-card">
                <p class="text-blue-600 font-black text-[11px] uppercase mb-6 tracking-widest flex items-center gap-2">
                    <i class="fas fa-font"></i> Teks Halaman Utama
                </p>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="input-label">Judul Flash Sale</label>
                        <input type="text" id="title_flash_sale" class="custom-input" placeholder="PASTI TERMURAH">
                    </div>
                    <div>
                        <label class="input-label">Judul Brand Populer</label>
                        <input type="text" id="title_popular" class="custom-input" placeholder="POPULER SEKARANG">
                    </div>
                </div>
            </div>

            <!-- SECTION 5: KONTAK & SOSIAL MEDIA -->
            <div class="config-card">
                <p class="text-blue-600 font-black text-[11px] uppercase mb-6 tracking-widest flex items-center gap-2">
                    <i class="fas fa-share-alt"></i> Kontak & Sosial Media
                </p>
                <div class="space-y-6">
                    <div>
                        <label class="input-label">WhatsApp Utama (Untuk Link di Footer)</label>
                        <input type="text" id="wa_link" class="custom-input" placeholder="Gunakan format: https://wa.me/628123...">
                    </div>
                    <div>
                        <label class="input-label">WhatsApp CS (Untuk Tombol Melayang / Floating)</label>
                        <input type="text" id="wa_cs" class="custom-input" placeholder="Contoh: 62812345678">
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="input-label">Instagram Username</label>
                            <input type="text" id="ig_link" class="custom-input" placeholder="@lanastore">
                        </div>
                        <div>
                            <label class="input-label">Link TikTok</label>
                            <input type="text" id="tiktok_link" class="custom-input" placeholder="https://tiktok.com/@...">
                        </div>
                    </div>
                </div>
            </div>

            <!-- Hint Box -->
            <div class="bg-slate-900 rounded-[32px] p-6 text-white shadow-xl mt-4 mb-10">
                <div class="flex items-start gap-4">
                    <i class="fas fa-info-circle text-blue-400 text-lg mt-1"></i>
                    <div>
                        <h4 class="font-bold text-sm mb-1">Penting</h4>
                        <p class="text-slate-400 text-[11px] leading-relaxed">
                            Pastikan Nama Toko dan Meta Deskripsi diisi dengan kata-kata yang sering dicari (Misal: Topup ML Murah) agar Google lebih mudah menemukan website Anda. Perubahan biaya admin akan langsung berpengaruh pada nominal bayar QRIS pelanggan.
                        </p>
                    </div>
                </div>
            </div>

        </main>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.0.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        async function loadConfig() {
            try {
                const res = await fetch('/api/admin/config');
                const json = await res.json();
                if(json.status && json.data) {
                    const d = json.data;
                    $('#shop_name').val(d.shop_name);
                    $('#meta_description').val(d.meta_description);
                    $('#meta_keywords').val(d.meta_keywords);
                    $('#logo_url').val(d.logo_url);
                    
                    $('#admin_fee').val(d.admin_fee);
                    $('#tax_percent').val(d.tax_percent);

                    $('#footer_description').val(d.footer_description);
                    $('#footer_trade_info').val(d.footer_trade_info);
                    
                    $('#title_flash_sale').val(d.title_flash_sale);
                    $('#title_popular').val(d.title_popular);
                    
                    $('#wa_link').val(d.wa_link);
                    $('#wa_cs').val(d.wa_cs);
                    $('#ig_link').val(d.ig_link);
                    $('#tiktok_link').val(d.tiktok_link);
                }
            } catch (e) { console.error("Gagal muat data"); }
        }

        async function saveSettings() {
            const btn = $('#btnSave');
            btn.attr('disabled', true).text('...');

            const data = {
                shop_name: $('#shop_name').val(),
                meta_description: $('#meta_description').val(),
                meta_keywords: $('#meta_keywords').val(),
                logo_url: $('#logo_url').val(),
                admin_fee: $('#admin_fee').val(),
                tax_percent: $('#tax_percent').val(),
                footer_description: $('#footer_description').val(),
                footer_trade_info: $('#footer_trade_info').val(),
                title_flash_sale: $('#title_flash_sale').val(),
                title_popular: $('#title_popular').val(),
                wa_link: $('#wa_link').val(),
                wa_cs: $('#wa_cs').val(),
                ig_link: $('#ig_link').val(),
                tiktok_link: $('#tiktok_link').val()
            };

            try {
                const res = await fetch('/api/admin/config', {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                const result = await res.json();
                if(result.status) {
                    Swal.fire({ icon: 'success', title: 'Berhasil Disimpan', timer: 1500, showConfirmButton: false });
                }
            } catch (e) { Swal.fire('Error', 'Gagal simpan data', 'error'); } 
            finally { btn.attr('disabled', false).text('Simpan'); }
        }

        $(document).ready(loadConfig);
    </script>
</body>
</html>
