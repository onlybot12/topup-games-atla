<!DOCTYPE html>
<html lang="id">
<head>
    <title>Admin - Pengaturan</title>
    <%- include('../partials/head') %>
</head>
<body class="bg-slate-50">
    <%- include('../partials/sidebar') %>
    <div id="main-content" class="lg:ml-64 min-h-screen">
        <header class="h-16 bg-white border-b px-6 flex items-center justify-between sticky top-0 z-40">
            <h1 class="font-bold text-slate-800">Pengaturan Sistem</h1>
            <button onclick="saveSettings()" id="btnSave" class="bg-blue-600 text-white px-6 py-2 rounded-xl text-[11px] font-black uppercase">Simpan</button>
        </header>

        <main class="p-6 max-w-4xl">
            <div class="bg-white rounded-[32px] border p-8 shadow-sm space-y-8">
                <!-- Bagian QRIS (Sudah ada sebelumnya) -->
                <div class="grid grid-cols-2 gap-6">
                    <div>
                        <label class="text-[10px] font-black text-slate-400 uppercase">Admin Fee (Rp)</label>
                        <input type="number" id="admin_fee" class="w-full bg-slate-50 border rounded-xl p-3 mt-1 font-bold">
                    </div>
                    <div>
                        <label class="text-[10px] font-black text-slate-400 uppercase">Pajak MDR (%)</label>
                        <input type="number" id="tax_percent" step="0.1" class="w-full bg-slate-50 border rounded-xl p-3 mt-1 font-bold">
                    </div>
                </div>

                <!-- Bagian Teks Halaman Depan (Baru) -->
                <div class="border-t pt-8 space-y-4">
                    <p class="text-[10px] font-black text-blue-500 uppercase tracking-widest">Teks Halaman Utama</p>
                    <div class="grid grid-cols-2 gap-6">
                        <div>
                            <label class="text-[10px] font-bold text-slate-400 uppercase">Judul Flash Sale</label>
                            <input type="text" id="title_flash_sale" class="w-full bg-slate-50 border rounded-xl p-3 mt-1 text-sm font-bold">
                        </div>
                        <div>
                            <label class="text-[10px] font-bold text-slate-400 uppercase">Judul Section Populer</label>
                            <input type="text" id="title_popular" class="w-full bg-slate-50 border rounded-xl p-3 mt-1 text-sm font-bold">
                        </div>
                    </div>
                </div>

                <!-- Link Sosmed -->
                <div class="border-t pt-8 space-y-4">
                    <p class="text-[10px] font-black text-blue-500 uppercase tracking-widest">Kontak & Sosial Media</p>
                    <div class="grid grid-cols-2 gap-6">
                        <input type="text" id="wa_link" class="bg-slate-50 border rounded-xl p-3 text-sm font-bold" placeholder="Link WhatsApp">
                        <input type="text" id="ig_link" class="bg-slate-50 border rounded-xl p-3 text-sm font-bold" placeholder="Link Instagram">
                        <input type="text" id="tiktok_link" class="bg-slate-50 border rounded-xl p-3 text-sm font-bold" placeholder="Link TikTok">
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.0.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        async function loadConfig() {
            const res = await fetch('/api/admin/config');
            const json = await res.json();
            if(json.status) {
                $('#admin_fee').val(json.data.admin_fee);
                $('#tax_percent').val(json.data.tax_percent);
                $('#title_flash_sale').val(json.data.title_flash_sale);
                $('#title_popular').val(json.data.title_popular);
                $('#wa_link').val(json.data.wa_link);
                $('#ig_link').val(json.data.ig_link);
                $('#tiktok_link').val(json.data.tiktok_link);
            }
        }

        async function saveSettings() {
            const data = {
                admin_fee: $('#admin_fee').val(),
                tax_percent: $('#tax_percent').val(),
                title_flash_sale: $('#title_flash_sale').val(),
                title_popular: $('#title_popular').val(),
                wa_link: $('#wa_link').val(),
                ig_link: $('#ig_link').val(),
                tiktok_link: $('#tiktok_link').val()
            };
            await fetch('/api/admin/config', { method: 'PUT', headers: {'Content-Type':'application/json'}, body: JSON.stringify(data) });
            Swal.fire({ icon: 'success', title: 'Tersimpan', showConfirmButton: false, timer: 1000 });
        }

        $(document).ready(loadConfig);
    </script>
</body>
</html>
