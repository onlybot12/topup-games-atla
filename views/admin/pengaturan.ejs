<!DOCTYPE html>
<html lang="id">
<head>
    <title>Admin - Pengaturan Sistem</title>
    <%- include('../partials/head') %>
    <style>
        .config-card { 
            background: white; 
            border: 1px solid #e2e8f0; 
            border-radius: 32px; 
            padding: 24px; 
            margin-bottom: 20px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        }
        .input-label {
            font-size: 10px;
            font-weight: 800;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            margin-bottom: 8px;
            display: block;
        }
        .custom-input {
            width: 100%;
            background-color: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 16px;
            padding: 12px 16px;
            font-size: 14px;
            font-weight: 700;
            color: #1e293b;
            outline: none;
            transition: all 0.2s;
        }
        .custom-input:focus {
            border-color: #3b82f6;
            background-color: white;
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
        }
        textarea.custom-input { min-height: 80px; resize: none; }

        /* Style untuk Tab Button */
        .tab-btn {
            padding: 8px 24px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: 700;
            transition: all 0.3s;
            border: none;
        }
        .tab-btn.active {
            background-color: #2563eb;
            color: white;
            box-shadow: 0 4px 12px rgba(37, 99, 235, 0.2);
        }
        .tab-btn.inactive {
            color: #64748b;
            background: transparent;
        }
        .tab-btn.inactive:hover {
            background-color: #f1f5f9;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-fade-in { animation: fadeIn 0.3s ease-out forwards; }
    </style>
</head>
<body class="bg-slate-50 overflow-x-hidden">

    <%- include('../partials/sidebar') %>

    <div id="main-content" class="lg:ml-64 min-h-screen">
        <!-- HEADER -->
        <header class="h-16 bg-white border-b border-slate-200 sticky top-0 z-40 px-4 flex items-center justify-between">
            <div class="flex items-center gap-3">
                <button onclick="toggleSidebar()" class="lg:hidden w-10 h-10 flex items-center justify-center rounded-xl bg-slate-50 border text-slate-600 active:scale-95 transition-all">
                    <i class="fas fa-bars-staggered"></i>
                </button>
                <h1 class="font-bold text-slate-800 text-sm uppercase tracking-tight">Pengaturan</h1>
            </div>
            <button onclick="saveSettings()" id="btnSave" class="bg-blue-600 text-white px-6 py-2 rounded-xl text-[11px] font-black uppercase shadow-lg shadow-blue-500/20 active:scale-95 transition-all">
                Simpan Semua
            </button>
        </header>

        <main class="p-4 md:p-8 max-w-4xl mx-auto">

            <!-- TAB NAVIGATION -->
            <div class="flex gap-2 mb-8 bg-white p-2 rounded-2xl border border-slate-200 w-fit shadow-sm">
                <button onclick="switchTab('umum')" id="btn-tab-umum" class="tab-btn active">Umum</button>
                <button onclick="switchTab('whatsapp')" id="btn-tab-whatsapp" class="tab-btn inactive">WhatsApp</button>
            </div>
            
            <!-- SECTION UMUM -->
            <div id="section-umum" class="animate-fade-in space-y-6">
                <!-- SEO & BRANDING -->
                <div class="config-card">
                    <p class="text-blue-600 font-black text-[11px] uppercase mb-6 tracking-widest flex items-center gap-2">
                        <i class="fas fa-search"></i> SEO & Branding
                    </p>
                    <div class="space-y-4">
                        <input type="text" id="shop_name" class="custom-input" placeholder="Nama Toko">
                        <textarea id="meta_description" class="custom-input" placeholder="Meta Deskripsi"></textarea>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <input type="text" id="meta_keywords" class="custom-input" placeholder="Keywords (pisah koma)">
                            <input type="text" id="logo_url" class="custom-input" placeholder="URL Logo">
                        </div>
                    </div>
                </div>

                <!-- BIAYA & PAJAK -->
                <div class="config-card">
                    <p class="text-blue-600 font-black text-[11px] uppercase mb-6 tracking-widest flex items-center gap-2">
                        <i class="fas fa-wallet"></i> Biaya Transaksi QRIS
                    </p>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                        <div>
                            <label class="input-label">Admin Fee (Rp)</label>
                            <input type="number" id="admin_fee" class="custom-input" placeholder="700">
                        </div>
                        <div>
                            <label class="input-label">Pajak MDR (%)</label>
                            <input type="number" id="tax_percent" step="0.1" class="custom-input" placeholder="1.6">
                        </div>
                        <div>
                            <label class="input-label">Biaya Tetap Vendor (Rp)</label>
                            <input type="number" id="vendor_fee_fixed" class="custom-input" placeholder="200">
                        </div>
                    </div>
                    <p class="text-[9px] text-slate-400 mt-4 italic">*Pajak MDR & Biaya Tetap biasanya mengikuti aturan Atlantic (cth: 1.6% + 200).</p>
                </div>

                <!-- FOOTER BRANDING -->
                <div class="config-card">
                    <p class="text-blue-600 font-black text-[11px] uppercase mb-6 tracking-widest flex items-center gap-2">
                        <i class="fas fa-shoe-prints"></i> Footer Branding
                    </p>
                    <div class="space-y-4">
                        <textarea id="footer_description" class="custom-input" placeholder="Deskripsi di bawah logo footer"></textarea>
                        <input type="text" id="footer_trade_info" class="custom-input" placeholder="Info kementerian/perdagangan">
                    </div>
                </div>

                <!-- TEKS HALAMAN DEPAN -->
                <div class="config-card">
                    <p class="text-blue-600 font-black text-[11px] uppercase mb-6 tracking-widest flex items-center gap-2">
                        <i class="fas fa-font"></i> Teks Halaman Utama
                    </p>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <input type="text" id="title_flash_sale" class="custom-input" placeholder="Judul Flash Sale">
                        <input type="text" id="title_popular" class="custom-input" placeholder="Judul Populer">
                    </div>
                </div>
            </div>

            <!-- SECTION WHATSAPP -->
            <div id="section-whatsapp" class="hidden animate-fade-in space-y-6">
                <div class="config-card border-green-200">
                    <p class="text-green-600 font-black text-[11px] uppercase mb-6 tracking-widest flex items-center gap-2">
                        <i class="fab fa-whatsapp text-lg"></i> WhatsApp Gateway API
                    </p>
                    <div class="space-y-6">
                        <div>
                            <label class="input-label">Ngechat API KEY</label>
                            <input type="text" id="wa_gateway_apikey" class="custom-input" placeholder="x-api-key">
                        </div>
                        <div>
                            <label class="input-label">Ngechat Session ID</label>
                            <input type="text" id="wa_gateway_session" class="custom-input" placeholder="Session ID">
                        </div>
                        
                        <div class="pt-4 border-t border-slate-100">
                            <p class="text-blue-600 font-black text-[11px] uppercase mb-4 tracking-widest">Kontak & CS</p>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                <input type="text" id="wa_link" class="custom-input" placeholder="Link WhatsApp Utama">
                                <input type="text" id="wa_cs" class="custom-input" placeholder="Nomor WA CS (628xxx)">
                                <input type="text" id="ig_link" class="custom-input" placeholder="Instagram Username">
                                <input type="text" id="tiktok_link" class="custom-input" placeholder="Link TikTok">
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Hint Box -->
            <div class="bg-slate-900 rounded-[32px] p-6 text-white shadow-xl mt-4 mb-10">
                <div class="flex items-start gap-4">
                    <i class="fas fa-info-circle text-blue-400 text-lg mt-1"></i>
                    <div>
                        <h4 class="font-bold text-sm mb-1">Informasi</h4>
                        <p class="text-slate-400 text-[11px] leading-relaxed">
                            Simpan perubahan untuk menerapkan pengaturan biaya admin, SEO, dan API WhatsApp secara real-time. Perubahan biaya admin akan langsung mempengaruhi kalkulasi pembayaran QRIS pembeli.
                        </p>
                    </div>
                </div>
            </div>

        </main>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.0.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function switchTab(tab) {
            if (tab === 'umum') {
                $('#section-umum').removeClass('hidden');
                $('#section-whatsapp').addClass('hidden');
                $('#btn-tab-umum').addClass('active').removeClass('inactive');
                $('#btn-tab-whatsapp').addClass('inactive').removeClass('active');
            } else {
                $('#section-umum').addClass('hidden');
                $('#section-whatsapp').removeClass('hidden');
                $('#btn-tab-whatsapp').addClass('active').removeClass('inactive');
                $('#btn-tab-umum').addClass('inactive').removeClass('active');
            }
        }

        async function loadConfig() {
            try {
                const res = await fetch('/api/admin/config');
                const json = await res.json();
                if(json.status && json.data) {
                    const d = json.data;
                    $('#shop_name').val(d.shop_name);
                    $('#meta_description').val(d.meta_description);
                    $('#meta_keywords').val(d.meta_keywords);
                    $('#logo_url').val(d.logo_url);
                    $('#admin_fee').val(d.admin_fee);
                    $('#tax_percent').val(d.tax_percent);
                    $('#vendor_fee_fixed').val(d.vendor_fee_fixed);
                    $('#footer_description').val(d.footer_description);
                    $('#footer_trade_info').val(d.footer_trade_info);
                    $('#title_flash_sale').val(d.title_flash_sale);
                    $('#title_popular').val(d.title_popular);
                    $('#wa_link').val(d.wa_link);
                    $('#wa_cs').val(d.wa_cs);
                    $('#ig_link').val(d.ig_link);
                    $('#tiktok_link').val(d.tiktok_link);
                    $('#wa_gateway_apikey').val(d.wa_gateway_apikey);
                    $('#wa_gateway_session').val(d.wa_gateway_session);
                }
            } catch (e) { console.error("Gagal muat data"); }
        }

        async function saveSettings() {
            const btn = $('#btnSave');
            btn.attr('disabled', true).text('Saving...');

            const data = {
                shop_name: $('#shop_name').val(),
                meta_description: $('#meta_description').val(),
                meta_keywords: $('#meta_keywords').val(),
                logo_url: $('#logo_url').val(),
                admin_fee: $('#admin_fee').val(),
                tax_percent: $('#tax_percent').val(),
                vendor_fee_fixed: $('#vendor_fee_fixed').val(),
                footer_description: $('#footer_description').val(),
                footer_trade_info: $('#footer_trade_info').val(),
                title_flash_sale: $('#title_flash_sale').val(),
                title_popular: $('#title_popular').val(),
                wa_link: $('#wa_link').val(),
                wa_cs: $('#wa_cs').val(),
                ig_link: $('#ig_link').val(),
                tiktok_link: $('#tiktok_link').val(),
                wa_gateway_apikey: $('#wa_gateway_apikey').val(),
                wa_gateway_session: $('#wa_gateway_session').val()
            };

            try {
                const res = await fetch('/api/admin/config', {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                const result = await res.json();
                if(result.status) {
                    Swal.fire({ icon: 'success', title: 'Berhasil Disimpan', timer: 1500, showConfirmButton: false });
                }
            } catch (e) { Swal.fire('Error', 'Gagal simpan data', 'error'); } 
            finally { btn.attr('disabled', false).text('Simpan Semua'); }
        }

        $(document).ready(loadConfig);
    </script>
</body>
</html>
