<!DOCTYPE html>
<html lang="id">
<head>
    <title>Admin - Kelola Popup Promo</title>
    <%- include('../partials/head') %>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap');
        body { font-family: 'Plus Jakarta Sans', sans-serif; background-color: #f8fafc; }
        
        /* Android Style Card */
        .popup-card {
            background: white;
            border: 1px solid #e2e8f0;
            border-radius: 28px;
            transition: all 0.3s ease;
            overflow: hidden;
        }
        .popup-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.05);
        }
        
        .swal-input-label { 
            font-size: 10px; 
            font-weight: 800; 
            color: #94a3b8; 
            text-transform: uppercase; 
            margin-bottom: 4px; 
            display: block; 
            margin-top: 12px; 
            letter-spacing: 0.05em;
        }
    </style>
</head>
<body class="bg-slate-50 overflow-x-hidden">

    <%- include('../partials/sidebar') %>

    <div id="main-content" class="lg:ml-64 min-h-screen">
    
        <header class="h-16 bg-white border-b border-slate-200 sticky top-0 z-40 px-4 md:px-6 flex items-center justify-between">
            <div class="flex items-center gap-3">
                <button onclick="toggleSidebar()" class="lg:hidden w-10 h-10 flex items-center justify-center rounded-xl bg-slate-50 border text-slate-600">
                    <i class="fas fa-bars-staggered"></i>
                </button>
                <h1 class="font-bold text-slate-800 text-sm uppercase tracking-tight">Kelola Popup</h1>
            </div>
            <button onclick="addPopup()" class="bg-blue-600 text-white px-5 py-2.5 rounded-2xl text-[11px] font-black uppercase shadow-lg shadow-blue-500/20 active:scale-95 transition-all">
                <i class="fas fa-plus mr-1"></i> Tambah Popup
            </button>
        </header>

        
        <main class="p-4 md:p-8">
            <div class="flex items-center gap-2 mb-6 px-2 text-slate-400">
                <i class="fas fa-info-circle text-xs"></i>
                <p class="text-[10px] font-bold uppercase tracking-wider m-0">Popup akan muncul secara otomatis di halaman utama pembeli.</p>
            </div>

            <!-- GRID POPUP -->
            <div id="popup-list" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                <!-- Data Popup akan dimuat via AJAX -->
                <div class="col-span-full py-20 text-center">
                    <div class="animate-spin h-8 w-8 border-4 border-blue-500 border-t-transparent rounded-full mx-auto mb-4"></div>
                    <p class="text-slate-400 font-bold uppercase text-[10px]">Memuat Data...</p>
                </div>
            </div>
        </main>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.0.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>


        async function loadPopups() {
            try {
                const res = await fetch('/api/admin/popups');
                const json = await res.json();
                const grid = $('#popup-list').empty();

                if(json.data.length === 0) {
                    grid.html('<div class="col-span-full py-20 text-center text-slate-400 font-bold uppercase text-xs">Belum ada popup promo.</div>');
                    return;
                }

                json.data.forEach(p => {
                    grid.append(`
                        <div class="popup-card shadow-sm flex flex-col h-full">
                            <div class="relative">
                                <img src="${p.image_url}" class="w-full aspect-square object-cover border-b" onerror="this.src='/api/placeholder/400/400'">
                                <div class="absolute top-3 left-3">
                                    <span class="bg-blue-600 text-white text-[9px] font-black px-3 py-1 rounded-full uppercase">Aktif</span>
                                </div>
                            </div>
                            
                            <div class="p-5 flex flex-col flex-grow">
                                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Deskripsi:</p>
                                <p class="text-xs text-slate-700 font-bold leading-relaxed mb-4 flex-grow italic">
                                    "${p.description || 'Tidak ada deskripsi'}"
                                </p>
                                
                                <div class="bg-slate-50 p-3 rounded-xl mb-5 border border-slate-100 overflow-hidden">
                                    <p class="text-[8px] font-black text-slate-400 uppercase mb-1">Link Tujuan:</p>
                                    <p class="text-[10px] text-blue-600 font-bold truncate">${p.target_link || 'Tanpa Link'}</p>
                                </div>

                                <button onclick="deletePopup('${p._id}')" class="w-full bg-red-50 text-red-500 py-3 rounded-2xl text-[10px] font-black uppercase active:scale-95 transition-all">
                                    <i class="fas fa-trash-alt mr-1"></i> Hapus Popup
                                </button>
                            </div>
                        </div>
                    `);
                });

            } catch (e) { console.error(e); }
        }

        async function addPopup() {
            const { value: f } = await Swal.fire({
                title: '<span class="text-xs font-black uppercase tracking-widest text-slate-800">Tambah Popup Promo</span>',
                width: '500px',
                confirmButtonText: 'SIMPAN POPUP',
                confirmButtonColor: '#2563eb',
                showCancelButton: true,
                html: `
                    <div class="text-left px-2">
                        <label class="swal-input-label">URL Gambar (Format Persegi/Kotak)</label>
                        <input id="p-img" class="swal2-input !mt-0 !text-sm" placeholder="https://link-gambar.com/promo.png">
                        
                        <label class="swal-input-label">Deskripsi Singkat</label>
                        <textarea id="p-desc" class="swal2-textarea !mt-0 !text-sm !h-24" placeholder="Info stock akun JB Alwi Kobra..."></textarea>

                        <label class="swal-input-label text-blue-600">Link Tujuan (Klik Gambar)</label>
                        <input id="p-link" class="swal2-input !mt-0 !text-sm" placeholder="Contoh: https://wa.me/channel/xxx">
                        <p class="text-[9px] text-slate-400 mt-2 font-bold uppercase italic leading-tight">
                            *Saran: Gunakan gambar berukuran 1000x1000 pixel agar terlihat tajam di HP pembeli.
                        </p>
                    </div>
                `,
                preConfirm: () => {
                    const img = $('#p-img').val();
                    if(!img) return Swal.showValidationMessage('URL Gambar wajib diisi!');
                    
                    return {
                        image_url: img,
                        description: $('#p-desc').val(),
                        target_link: $('#p-link').val()
                    }
                }
            });

            if (f) {
                try {
                    const res = await fetch('/api/admin/popups', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(f)
                    });
                    const result = await res.json();
                    if(result.status) {
                        Swal.fire({ icon: 'success', title: 'Tersimpan', showConfirmButton: false, timer: 1500 });
                        loadPopups();
                    }
                } catch (e) { alert("Error Server"); }
            }
        }

        async function deletePopup(id) {
            const ask = await Swal.fire({
                title: 'Hapus Popup?',
                text: "Data ini akan hilang permanen dari website!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                confirmButtonText: 'YA, HAPUS'
            });

            if (ask.isConfirmed) {
                await fetch(`/api/admin/popups/${id}`, { method: 'DELETE' });
                loadPopups();
            }
        }

        // Jalankan load data saat halaman siap
        $(document).ready(loadPopups);
    </script>
</body>
</html>
