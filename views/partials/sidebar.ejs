<!-- Sidebar Overlay -->
<div id="sidebar-overlay" 
     class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-[9998] hidden opacity-0 transition-opacity duration-300" 
     onclick="toggleSidebar()">
</div>

<!-- Sidebar Container -->
<aside id="sidebar" 
       class="fixed inset-y-0 left-0 w-64 bg-slate-900 text-slate-400 flex flex-col z-[9999] transform -translate-x-full lg:translate-x-0 transition-transform duration-300 ease-in-out shadow-2xl">
    
    <div class="p-6 border-b border-slate-800 flex items-center justify-between text-white font-black text-xl">
        <span><i class="fas fa-rocket text-blue-500 mr-2"></i>LANA ADMIN</span>
        <button onclick="toggleSidebar()" class="lg:hidden text-slate-500 hover:text-white p-2">
            <i class="fas fa-times"></i>
        </button>
    </div>
    
    <nav class="flex-1 p-4 space-y-2 no-scrollbar overflow-y-auto">
        <p class="px-4 py-2 text-[10px] font-black text-slate-500 uppercase tracking-[0.2em]">Data Produk</p>
        <a href="/admin/brand" class="w-full flex items-center gap-3 px-4 py-3 rounded-xl transition-all <%= currentPage === 'brand' ? 'bg-blue-600 text-white shadow-lg font-bold' : 'hover:bg-slate-800' %>">
            <i class="fas fa-tags"></i> <span>Kelola Brand</span>
        </a>
        <a href="/admin/layanan" class="w-full flex items-center gap-3 px-4 py-3 rounded-xl transition-all <%= currentPage === 'layanan' ? 'bg-blue-600 text-white shadow-lg font-bold' : 'hover:bg-slate-800' %>">
            <i class="fas fa-box"></i> <span>Kelola Layanan</span>
        </a>

        <p class="px-4 py-2 mt-4 text-[10px] font-black text-slate-500 uppercase tracking-[0.2em]">Marketing</p>
        <a href="/admin/banner" class="w-full flex items-center gap-3 px-4 py-3 rounded-xl transition-all <%= currentPage === 'banner' ? 'bg-blue-600 text-white shadow-lg font-bold' : 'hover:bg-slate-800' %>">
            <i class="fas fa-images"></i> <span>Kelola Banner</span>
        </a>
        <a href="/admin/flash-sale" class="w-full flex items-center gap-3 px-4 py-3 rounded-xl transition-all <%= currentPage === 'flashsale' ? 'bg-blue-600 text-white shadow-lg font-bold' : 'hover:bg-slate-800' %>">
            <i class="fas fa-bolt"></i> <span>Flash Sale</span>
        </a>
        <a href="/admin/voucher" class="w-full flex items-center gap-3 px-4 py-3 rounded-xl transition-all <%= currentPage === 'voucher' ? 'bg-blue-600 text-white shadow-lg font-bold' : 'hover:bg-slate-800' %>">
            <i class="fas fa-ticket-alt"></i> <span>Voucher Promo</span>
        </a>

        <p class="px-4 py-2 mt-4 text-[10px] font-black text-slate-500 uppercase tracking-[0.2em]">Sistem</p>
        <a href="/admin/pengaturan" class="w-full flex items-center gap-3 px-4 py-3 rounded-xl transition-all <%= currentPage === 'pengaturan' ? 'bg-blue-600 text-white shadow-lg font-bold' : 'hover:bg-slate-800' %>">
            <i class="fas fa-cog"></i> <span>Pengaturan</span>
        </a>
        
        <div class="my-4 border-t border-slate-800"></div>
        <a href="/" class="w-full flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-slate-800">
            <i class="fas fa-external-link-alt text-blue-400"></i> <span>Lihat Toko</span>
        </a>
    </nav>
</aside>

<script>
    function toggleSidebar() {
        const sidebar = document.getElementById('sidebar');
        const overlay = document.getElementById('sidebar-overlay');
        
        // Menggunakan logika pemeriksaan class yang lebih kuat
        const isHidden = sidebar.classList.contains('-translate-x-full');
        
        if (isHidden) {
            // TAMPILKAN
            sidebar.classList.remove('-translate-x-full');
            sidebar.classList.add('translate-x-0'); // Paksa ke posisi 0
            overlay.classList.remove('hidden');
            setTimeout(() => overlay.classList.add('opacity-100'), 10);
            document.body.style.overflow = 'hidden'; 
        } else {
            // SEMBUNYIKAN
            sidebar.classList.add('-translate-x-full');
            sidebar.classList.remove('translate-x-0');
            overlay.classList.remove('opacity-100');
            setTimeout(() => overlay.classList.add('hidden'), 300);
            document.body.style.overflow = 'auto'; 
        }
    }
</script>
