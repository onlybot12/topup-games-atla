<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">

<!-- ==========================
     SEO & BRANDING DINAMIS
     ========================== -->
<% if (typeof config !== 'undefined' && config.shop_name) { %>
    <!-- Judul yang muncul di Tab Browser & Google -->
    <title><%= config.shop_name %> - <%= config.meta_description %></title>
    
    <!-- Meta Deskripsi & Keywords untuk SEO -->
    <meta name="description" content="<%= config.meta_description %>">
    <meta name="keywords" content="<%= config.meta_keywords %>">
    <meta name="author" content="<%= config.shop_name %>">

    <!-- Open Graph (Agar saat link dishare ke WA/FB muncul Gambar & Judul rapi) -->
    <meta property="og:title" content="<%= config.shop_name %>">
    <meta property="og:description" content="<%= config.meta_description %>">
    <meta property="og:image" content="<%= config.logo_url %>">
    <meta property="og:url" content="/">
    <meta property="og:type" content="website">

    <!-- Favicon (Ikon Kecil di Tab Browser) -->
    <link rel="icon" type="image/png" href="<%= config.logo_url %>">
<% } else { %>
    <title>Lana Store - Topup Game Murah & Cepat</title>
<% } %>

<!-- CSS & Library -->
<script src="https://cdn.tailwindcss.com"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap');
    
    * { -webkit-tap-highlight-color: transparent; }
    body { font-family: 'Inter', sans-serif; }
    
    .hide-scrollbar::-webkit-scrollbar { display: none; }
    .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    
    @keyframes fadeIn { 
        from { opacity: 0; transform: translateY(10px); } 
        to { opacity: 1; transform: translateY(0); } 
    }
    .fade-in { animation: fadeIn 0.3s ease-out; }
    .sidebar-open { transform: translateX(0) !important; }
</style>

<script>
    tailwind.config = {
        theme: {
            extend: {
                colors: {
                    dark: { 
                        50: '#f8fafc', 100: '#f1f5f9', 200: '#e2e8f0', 300: '#cbd5e1', 
                        400: '#94a3b8', 500: '#64748b', 600: '#475569', 700: '#334155', 
                        800: '#1e293b', 900: '#0f172a' 
                    }
                }
            }
        }
    }
</script>
