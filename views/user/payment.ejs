<!DOCTYPE html>
<html lang="id">
<head>
    <title>Pembayaran - <%= config.shop_name %></title>
    <%- include('../partials/user/heads') %>
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #0f172a; color: #f8fafc; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        .fade-in { animation: fadeIn 0.3s ease-out; }
        .status-transition { transition: all 0.5s ease; }
    </style>
</head>
<body class="bg-dark-900 text-gray-100">

    <div id="mainContent" class="fade-in max-w-2xl mx-auto px-4 py-6 pb-20">
        
        <!-- Header -->
        <div class="flex items-center justify-between mb-8">
            <a href="/" class="w-10 h-10 rounded-xl bg-dark-800 border border-dark-700 flex items-center justify-center hover:bg-dark-700 transition-colors">
                <i class="fas fa-arrow-left"></i>
            </a>
            <h2 class="font-bold text-lg">Konfirmasi Pembayaran</h2>
            <div class="bg-dark-800 px-3 py-1 rounded-lg border border-dark-700">
                <span id="qrTimer" class="text-blue-400 font-mono font-bold">60:00</span>
            </div>
        </div>

        <!-- Status Badge Dinamis -->
        <div class="text-center mb-8">
            <div id="statusBadge" class="status-transition inline-block bg-yellow-500/20 text-yellow-400 text-[10px] font-black uppercase px-5 py-2.5 rounded-full border border-yellow-500/10 tracking-widest">
                <i class="fas fa-clock mr-1"></i> <span id="statusTextHeader">MENUNGGU PEMBAYARAN</span>
            </div>
        </div>

        <!-- QRIS Section -->
        <div class="bg-dark-800 border border-dark-700 rounded-[40px] p-8 mb-6 text-center shadow-2xl relative overflow-hidden">
            <div class="absolute top-0 right-0 w-32 h-32 bg-blue-500/5 rounded-full -mr-16 -mt-16"></div>
            
            <p class="text-xs text-gray-400 mb-6 font-medium">Scan QRIS di bawah ini untuk membayar otomatis</p>
            
            <div class="bg-white p-4 rounded-[32px] inline-block mb-6 shadow-2xl shadow-blue-500/10">
                <img id="qrImage" src="<%= tr.qr_image %>" class="w-64 h-64 mx-auto rounded-xl">
            </div>

            <h2 class="text-3xl font-black text-white">Rp <%= tr.amount.toLocaleString('id-ID') %></h2>
            <p class="text-[10px] text-slate-500 font-bold uppercase tracking-[0.3em] mt-3">Lana Payment Engine</p>
        </div>

        <!-- Informasi Transaksi -->
        <div class="bg-dark-800 border border-dark-700 rounded-[32px] p-6 space-y-4 mb-4 shadow-lg">
            <div class="flex justify-between items-center border-b border-dark-700 pb-3">
                <span class="text-gray-500 text-[10px] font-black uppercase tracking-wider">Order ID</span>
                <div class="flex items-center gap-2">
                    <span class="font-mono text-sm font-bold text-blue-400"><%= tr.order_id %></span>
                    <button onclick="copyText('<%= tr.order_id %>')" class="text-gray-500 hover:text-white"><i class="far fa-copy"></i></button>
                </div>
            </div>
            <div class="flex justify-between items-center border-b border-dark-700 pb-3">
                <span class="text-gray-500 text-[10px] font-black uppercase tracking-wider">Produk</span>
                <span class="text-sm font-bold text-white"><%= tr.item_name %></span>
            </div>
            <div class="flex justify-between items-center border-b border-dark-700 pb-3">
                <span class="text-gray-500 text-[10px] font-black uppercase tracking-wider">Tujuan</span>
                <span class="text-sm font-mono text-gray-300"><%= tr.target %></span>
            </div>
            <div class="flex justify-between items-center pt-2">
                <span class="text-gray-500 text-[10px] font-black uppercase tracking-wider">Status</span>
                <span id="statusTextDetail" class="text-sm font-bold text-yellow-500 uppercase">BELUM DIBAYAR</span>
            </div>
        </div>

        <!-- Butuh Bantuan -->
        <div class="bg-dark-800 border border-dark-700 rounded-[32px] p-6 mt-8">
            <h3 class="font-black text-white text-sm mb-2 uppercase">Butuh Bantuan?</h3>
            <p class="text-xs text-gray-500 mb-6 font-medium leading-relaxed">Jika Anda mengalami kendala atau saldo belum masuk setelah 5 menit, silakan hubungi Customer Service kami.</p>
            <a href="https://wa.me/<%= config.wa_cs %>?text=Halo admin, saya butuh bantuan untuk Order ID: <%= tr.order_id %>" 
               class="block w-full bg-green-600/10 border border-green-500/20 text-green-500 text-center py-4 rounded-2xl font-black text-xs uppercase tracking-widest hover:bg-green-600 hover:text-white transition-all">
                <i class="fab fa-whatsapp mr-2 text-base"></i> Hubungi WhatsApp CS
            </a>
        </div>

        <a href="/" class="block text-center mt-10 text-gray-600 text-[10px] font-black uppercase tracking-[0.4em] hover:text-white transition-all">
            LANA STORE • KEMBALI KE BERANDA
        </a>
    </div>

    <!-- Success Modal -->
    <div id="successModal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-6 backdrop-blur-md bg-black/80">
        <div class="bg-dark-800 border border-dark-700 rounded-[40px] p-8 w-full max-w-sm text-center shadow-2xl fade-in">
            <div class="w-20 h-20 bg-green-500/20 text-green-500 rounded-full flex items-center justify-center mx-auto mb-6 text-3xl shadow-lg shadow-green-500/10">
                <i class="fas fa-check"></i>
            </div>
            <h3 class="text-2xl font-black text-white mb-2 tracking-tight uppercase">Berhasil!</h3>
            <p class="text-gray-400 text-sm mb-6 font-medium">Pembayaran telah diterima & pesanan dikirim.</p>
            
            <div class="bg-dark-900 border border-dark-700 rounded-2xl p-5 text-left mb-8">
                <label class="text-[9px] font-black text-gray-500 uppercase tracking-widest mb-1 block">Serial Number (SN)</label>
                <p id="snDisplay" class="font-mono font-bold text-blue-400 break-all text-sm">Memproses SN...</p>
            </div>
            
            <button onclick="window.location.href='/'" class="w-full bg-blue-600 text-white py-4 rounded-[20px] font-black uppercase tracking-widest shadow-lg shadow-blue-900/40 active:scale-95 transition-all">Selesai</button>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script>
        const depositId = "<%= tr.deposit_id %>";
        const meta = <%- JSON.stringify(tr.meta) %>;

        // FUNGSI UPDATE STATUS VISUAL
        function updateStatus(type, text) {
            const badge = document.getElementById('statusBadge');
            const textHeader = document.getElementById('statusTextHeader');
            const textDetail = document.getElementById('statusTextDetail');

            // Reset class
            badge.className = "status-transition inline-block text-[10px] font-black uppercase px-5 py-2.5 rounded-full border tracking-widest ";
            
            if(type === 'paid') {
                badge.classList.add('bg-blue-500/20', 'text-blue-400', 'border-blue-500/20');
                textDetail.className = "text-sm font-bold text-blue-400 uppercase";
            } else if (type === 'processing') {
                badge.classList.add('bg-purple-500/20', 'text-purple-400', 'border-purple-500/20');
                textDetail.className = "text-sm font-bold text-purple-400 uppercase";
            } else if (type === 'success') {
                badge.classList.add('bg-green-500/20', 'text-green-400', 'border-green-500/20');
                textDetail.className = "text-sm font-bold text-green-400 uppercase";
            }

            textHeader.innerText = text;
            textDetail.innerText = text;
        }

        function checkStatus() {
            const checkInterval = setInterval(async () => {
                try {
                    const res = await axios.post('/api/check-status', { deposit_id: depositId, meta: meta });
                    
                    if(res.data.state === 'success') {
                        clearInterval(checkInterval);
                        
                        // Step 1: Berhasil Bayar
                        updateStatus('paid', 'PEMBAYARAN BERHASIL');
                        
                        // Step 2: Proses Kirim (Delay Visual)
                        setTimeout(() => {
                            updateStatus('processing', 'MEMPROSES TRANSAKSI');
                        }, 800);

                        // Step 3: Munculkan Modal Sukses
                        setTimeout(() => {
                            updateStatus('success', 'TRANSAKSI BERHASIL');
                            document.getElementById('successModal').classList.remove('hidden');
                            document.getElementById('snDisplay').innerText = res.data.sn || "Sukses";
                            saveToLocal(res.data.sn);
                        }, 2000);

                    } else if(res.data.state === 'failed') {
                        clearInterval(checkInterval);
                        alert("Gagal: " + res.data.message);
                    }
                } catch (e) {}
            }, 3000);
        }

        function saveToLocal(sn) {
            let history = JSON.parse(localStorage.getItem('ray_history') || '[]');
            history.unshift({ trx_id: 'TRX'+depositId.substr(-6), item_name: "<%= tr.item_name %>", price: "<%= tr.amount %>", sn: sn, date: new Date().toLocaleString() });
            localStorage.setItem('ray_history', JSON.stringify(history.slice(0, 20)));
        }

        function startTimer(duration) {
            let timer = duration, minutes, seconds;
            const display = document.getElementById('qrTimer');
            setInterval(() => {
                minutes = parseInt(timer / 60, 10);
                seconds = parseInt(timer % 60, 10);
                display.textContent = (minutes < 10 ? "0" + minutes : minutes) + ":" + (seconds < 10 ? "0" + seconds : seconds);
                if (--timer < 0) window.location.href = "/";
            }, 1000);
        }

        function copyText(txt) {
            navigator.clipboard.writeText(txt);
            alert("Berhasil disalin: " + txt);
        }

        window.onload = () => {
            checkStatus();
            startTimer(3600);
        };
    </script>
</body>
</html>
