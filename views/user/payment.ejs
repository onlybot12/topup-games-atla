<!DOCTYPE html>
<html lang="id">
<head>
    <title>Pembayaran - <%= config.shop_name %></title>
    <%- include('../partials/user/heads') %>
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #0f172a; color: #f8fafc; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        .fade-in { animation: fadeIn 0.3s ease-out forwards; }
        .status-transition { transition: all 0.5s ease; }
        .receipt-line { border-bottom: 1px dashed #334155; padding-bottom: 12px; margin-bottom: 12px; }
    </style>
</head>
<body class="bg-dark-900 text-gray-100">

    <div id="mainContent" class="fade-in max-w-2xl mx-auto px-4 py-6 pb-20">
        
        <!-- Header -->
        <div class="flex items-center justify-between mb-8">
            <a href="/" class="w-10 h-10 rounded-xl bg-dark-800 border border-dark-700 flex items-center justify-center text-gray-400">
                <i class="fas fa-arrow-left"></i>
            </a>
            <div class="text-center">
                <p class="text-[10px] font-black text-gray-500 uppercase tracking-widest">ORDER ID</p>
                <p class="font-mono font-bold text-blue-400 text-sm"><%= tr.order_id %></p>
            </div>
            <div class="w-10"></div>
        </div>

        <!-- Status Badge Dinamis -->
        <div class="text-center mb-8">
            <div id="statusBadge" class="status-transition inline-block bg-yellow-500/20 text-yellow-400 text-[10px] font-black uppercase px-5 py-2.5 rounded-full border border-yellow-500/10 tracking-widest">
                <i id="statusIcon" class="fas fa-clock mr-1"></i> <span id="statusTextHeader">MENUNGGU PEMBAYARAN</span>
            </div>
        </div>

        <!-- 1. BAGIAN QRIS (Akan hilang saat sukses) -->
        <div id="qrisContainer" class="bg-dark-800 border border-dark-700 rounded-[40px] p-8 mb-6 text-center shadow-2xl relative overflow-hidden">
            <div class="absolute top-0 right-0 w-32 h-32 bg-blue-500/5 rounded-full -mr-16 -mt-16"></div>
            <p class="text-xs text-gray-400 mb-6 font-medium">Scan QRIS untuk membayar otomatis</p>
            <div class="bg-white p-4 rounded-[32px] inline-block mb-6 shadow-2xl">
                <img id="qrImage" src="<%= tr.qr_image %>" class="w-64 h-64 mx-auto rounded-xl">
            </div>
            <h2 class="text-3xl font-black text-white">Rp <%= tr.amount.toLocaleString('id-ID') %></h2>
            <div class="mt-4 flex justify-center">
                <span id="qrTimer" class="text-blue-400 font-mono font-bold text-xs bg-dark-900 px-3 py-1 rounded-lg">60:00</span>
            </div>
        </div>

        <!-- 2. BAGIAN HASIL TRANSAKSI (Muncul saat sukses) -->
        <div id="successResult" class="hidden bg-dark-800 border border-dark-700 rounded-[40px] p-8 mb-6 shadow-2xl fade-in">
            <div class="text-center mb-8">
                <div class="w-16 h-16 bg-green-500/20 text-green-500 rounded-full flex items-center justify-center mx-auto mb-4 text-2xl shadow-lg shadow-green-500/10">
                    <i class="fas fa-check"></i>
                </div>
                <h3 class="text-xl font-black text-white uppercase tracking-tight">Transaksi Berhasil!</h3>
                <p class="text-xs text-gray-500 mt-1 font-medium">Item telah berhasil dikirim ke akun Anda.</p>
            </div>

            <div class="space-y-4">
                <div class="receipt-line flex justify-between items-start">
                    <span class="text-gray-500 font-bold uppercase text-[9px] tracking-widest mt-1">Produk Layanan</span>
                    <span class="text-sm font-bold text-white text-right w-2/3"><%= tr.item_name %></span>
                </div>
                <div class="receipt-line flex justify-between">
                    <span class="text-gray-500 font-bold uppercase text-[9px] tracking-widest mt-1">ID Tujuan</span>
                    <span class="text-sm font-mono text-blue-400 font-bold tracking-tighter"><%= tr.target %></span>
                </div>
                <div class="receipt-line flex justify-between">
                    <span class="text-gray-500 font-bold uppercase text-[9px] tracking-widest mt-1">Nomor WhatsApp</span>
                    <span class="text-sm font-bold text-white"><%= tr.whatsapp %></span>
                </div>
                <div class="receipt-line flex justify-between">
                    <span class="text-gray-500 font-bold uppercase text-[9px] tracking-widest mt-1">Status</span>
                    <span class="text-[10px] font-black text-green-500 uppercase">SUKSES TERKIRIM</span>
                </div>
                <div class="p-4 bg-dark-900 border border-dark-700 rounded-2xl">
                    <label class="text-[9px] font-black text-gray-500 uppercase tracking-widest mb-1 block">Serial Number (SN)</label>
                    <p id="snDisplay" class="font-mono font-bold text-blue-400 break-all text-sm">Sedang mengambil SN...</p>
                </div>
            </div>

            <button onclick="window.location.href='/'" class="w-full bg-blue-600 text-white py-4 rounded-2xl font-black uppercase tracking-widest shadow-xl shadow-blue-900/40 active:scale-95 transition-all mt-8">
                Selesai
            </button>
        </div>

        <!-- Detail Pesanan (Informasi di bawah QRIS) -->
        <div id="orderInfoBox" class="bg-dark-800 border border-dark-700 rounded-[32px] p-6 space-y-4 shadow-lg">
            <div class="flex justify-between items-center border-b border-dark-700 pb-3 text-sm">
                <span class="text-gray-500 font-bold uppercase text-[10px]">Produk</span>
                <span class="font-bold text-white"><%= tr.item_name %></span>
            </div>
            <div class="flex justify-between items-center border-b border-dark-700 pb-3 text-sm">
                <span class="text-gray-500 font-bold uppercase text-[10px]">Tujuan</span>
                <span class="font-mono text-blue-300"><%= tr.target %></span>
            </div>
            <div class="flex justify-between items-center pt-2 text-sm">
                <span class="text-gray-500 font-bold uppercase text-[10px]">Update Terakhir</span>
                <span id="statusTextDetail" class="font-black text-yellow-500 uppercase">BELUM DIBAYAR</span>
            </div>
        </div>

        <div class="bg-dark-800 border border-dark-700 rounded-[32px] p-6 mt-8">
            <a href="https://wa.me/<%= config.wa_cs %>?text=Halo admin, saya butuh bantuan untuk Order ID: <%= tr.order_id %>" 
               class="block w-full bg-green-600/10 border border-green-500/20 text-green-500 text-center py-4 rounded-2xl font-black text-xs uppercase tracking-widest hover:bg-green-600 hover:text-white transition-all">
                <i class="fab fa-whatsapp mr-2 text-base"></i> Hubungi WhatsApp CS
            </a>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script>
        const depositId = "<%= tr.deposit_id %>";
        const meta = <%- JSON.stringify(tr.meta) %>;

        function updateStatusUI(step) {
            const badge = document.getElementById('statusBadge');
            const icon = document.getElementById('statusIcon');
            const textHeader = document.getElementById('statusTextHeader');
            const textDetail = document.getElementById('statusTextDetail');

            if(step === 'paid') {
                badge.className = "status-transition inline-block bg-blue-500/20 text-blue-400 text-[10px] font-black uppercase px-5 py-2.5 rounded-full border border-blue-500/20 tracking-widest";
                icon.className = "fas fa-check-double mr-1";
                textHeader.innerText = "PEMBAYARAN DITERIMA";
                textDetail.innerText = "DIBAYAR";
                textDetail.className = "font-black text-blue-400 uppercase";
            } else if (step === 'processing') {
                badge.className = "status-transition inline-block bg-purple-500/20 text-purple-400 text-[10px] font-black uppercase px-5 py-2.5 rounded-full border border-purple-500/20 tracking-widest";
                icon.className = "fas fa-sync fa-spin mr-1";
                textHeader.innerText = "MENGIRIM PRODUK";
                textDetail.innerText = "PROSES PENGIRIMAN";
                textDetail.className = "font-black text-purple-400 uppercase";
            } else if (step === 'success') {
                badge.className = "status-transition inline-block bg-green-500/20 text-green-400 text-[10px] font-black uppercase px-5 py-2.5 rounded-full border border-green-500/20 tracking-widest";
                icon.className = "fas fa-check mr-1";
                textHeader.innerText = "TRANSAKSI SELESAI";
                textDetail.innerText = "SUKSES";
                textDetail.className = "font-black text-green-400 uppercase";
            }
        }

        function checkStatus() {
            const checkInterval = setInterval(async () => {
                try {
                    const res = await axios.post('/api/check-status', { deposit_id: depositId, meta: meta });
                    
                    if(res.data.state === 'success') {
                        clearInterval(checkInterval);
                        
                        // 1. Tanda Pembayaran Sukses
                        updateStatusUI('paid');
                        
                        // 2. Simulasi Proses Pengiriman (Biar Terlihat Otomatis)
                        setTimeout(() => {
                            updateStatusUI('processing');
                        }, 1200);

                        // 3. Tampilkan Struk Lengkap
                        setTimeout(() => {
                            updateStatusUI('success');
                            
                            // HIDE QRIS & INFO BOX LAMA
                            document.getElementById('qrisContainer').classList.add('hidden');
                            document.getElementById('orderInfoBox').classList.add('hidden');
                            
                            // SHOW RESULT LENGKAP
                            document.getElementById('successResult').classList.remove('hidden');
                            document.getElementById('snDisplay').innerText = res.data.sn || "Cek Riwayat Game";
                            
                            saveToHistory(res.data.sn);
                        }, 3500);

                    } else if(res.data.state === 'failed') {
                        clearInterval(checkInterval);
                        alert("Gagal: " + res.data.message);
                    }
                } catch (e) {}
            }, 3000);
        }

        function saveToHistory(sn) {
            let history = JSON.parse(localStorage.getItem('ray_history') || '[]');
            history.unshift({ trx_id: 'TRX'+depositId.substr(-6), item_name: "<%= tr.item_name %>", price: "<%= tr.amount %>", sn: sn, date: new Date().toLocaleString() });
            localStorage.setItem('ray_history', JSON.stringify(history.slice(0, 20)));
        }

        function startTimer(duration) {
            let timer = duration, minutes, seconds;
            const display = document.getElementById('qrTimer');
            setInterval(() => {
                minutes = parseInt(timer / 60, 10);
                seconds = parseInt(timer % 60, 10);
                display.textContent = (minutes < 10 ? "0" + minutes : minutes) + ":" + (seconds < 10 ? "0" + seconds : seconds);
                if (--timer < 0) window.location.href = "/";
            }, 1000);
        }

        window.onload = () => {
            checkStatus();
            startTimer(3600);
        };
    </script>
</body>
</html>
