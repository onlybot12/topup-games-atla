<!DOCTYPE html>
<html lang="id">
<head>
    <title>Cari Transaksi - <%= config.shop_name %></title>
    <%- include('../partials/user/heads') %>
</head>
<body class="bg-dark-900 text-gray-100 min-h-screen pb-20">

    <%- include('../partials/sidebar-user') %>

    <!-- Header / Navbar -->
    <header class="sticky top-0 z-40 bg-dark-900/90 backdrop-blur-lg border-b border-dark-700 px-4 py-4 flex items-center gap-3">
        <button onclick="toggleSidebar()" class="w-10 h-10 flex items-center justify-center rounded-xl bg-dark-800 text-gray-400 active:scale-90 transition-all">
            <i class="fas fa-bars-staggered"></i>
        </button>
        <h1 class="font-black text-sm uppercase tracking-tight text-white">Cari Pesanan</h1>
    </header>

    <main class="max-w-2xl mx-auto px-4 py-6">
        
        <!-- Breadcrumb -->
        <nav class="flex items-center gap-2 text-[10px] mb-6 text-gray-500 font-bold uppercase tracking-widest">
            <a href="/" class="hover:text-blue-500 transition-colors">Home</a>
            <i class="fas fa-chevron-right text-[8px]"></i>
            <span class="text-gray-300">Cari Transaksi</span>
        </nav>

        <!-- Search Card -->
        <div class="bg-dark-800 border border-dark-700 rounded-[32px] p-8 mb-8 shadow-xl">
            <h2 class="text-xl font-black mb-3 text-center text-white uppercase tracking-tight">Lacak Pesanan</h2>
            <p class="text-gray-400 text-xs text-center mb-8 leading-relaxed font-medium">
                Pesanan kamu tidak terdaftar? Harap tunggu 1-5 menit proses sistem. Jika lebih dari 30 menit hubungi admin.
            </p>

            <div class="mb-6">
                <label class="text-[10px] font-black text-gray-500 mb-3 block uppercase tracking-widest ml-1">ID Transaksi / Order ID</label>
                <input type="text" id="searchTrxId" placeholder="Contoh: ORD-678910..." 
                    class="w-full bg-dark-900 border border-dark-700 rounded-2xl px-5 py-4 focus:border-blue-500 outline-none text-white font-bold placeholder-gray-600 transition-all">
            </div>
            
            <button onclick="searchTransaction()" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-black py-4 rounded-2xl transition-all flex items-center justify-center gap-2 shadow-lg shadow-blue-900/20 active:scale-95 uppercase text-sm tracking-widest">
                Cari Pesanan
                <i class="fas fa-search text-xs"></i>
            </button>
        </div>

        <!-- Transaksi Terakhir -->
        <div class="mb-10 reveal active">
            <div class="flex items-center gap-2 mb-2 ml-1">
                <span class="w-1.5 h-4 bg-blue-600 rounded-full"></span>
                <h3 class="text-sm font-black text-white uppercase tracking-tight">Transaksi Terakhir</h3>
            </div>
            <p class="text-[10px] text-gray-500 mb-4 ml-1 font-bold uppercase tracking-widest">Data pesanan masuk terbaru di <%= config.shop_name %>.</p>
            
            <!-- Loading State -->
            <div id="loadingTransactions" class="text-center py-12">
                <div class="inline-block w-8 h-8 border-4 border-blue-600 border-t-transparent rounded-full animate-spin"></div>
                <p class="text-gray-500 text-[10px] font-black uppercase mt-4 tracking-widest">Sinkronisasi Data...</p>
            </div>

            <!-- Table Responsive Wrapper -->
            <div id="transactionsTable" class="hidden overflow-hidden rounded-2xl border border-dark-700 shadow-sm">
                <div class="overflow-x-auto no-scrollbar">
                    <table class="w-full text-[11px] text-left">
                        <thead class="bg-dark-800 text-gray-500 font-black uppercase tracking-widest border-b border-dark-700">
                            <tr>
                                <th class="px-4 py-4">Invoice</th>
                                <th class="px-4 py-4">Tujuan</th>
                                <th class="px-4 py-4">Status</th>
                            </tr>
                        </thead>
                        <tbody id="transactionsBody" class="divide-y divide-dark-700 bg-dark-800/30">
                            <!-- Data injected via JS -->
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Hubungi Kami -->
        <div class="grid grid-cols-1 gap-3">
            <a href="<%= config.wa_link || '#' %>" target="_blank" 
                class="flex items-center justify-between px-6 py-4 bg-dark-800 border border-dark-700 rounded-2xl hover:border-green-500 transition-all group">
                <div class="flex items-center gap-4">
                    <div class="w-10 h-10 bg-green-500/10 rounded-xl flex items-center justify-center text-green-500">
                        <i class="fab fa-whatsapp text-xl"></i>
                    </div>
                    <div>
                        <p class="text-xs font-black text-white uppercase tracking-tight">WhatsApp Admin</p>
                        <p class="text-[9px] text-gray-500 font-bold uppercase tracking-widest">Hubungi jika ada kendala</p>
                    </div>
                </div>
                <i class="fas fa-chevron-right text-gray-700 group-hover:text-green-500 transition-all"></i>
            </a>
        </div>

    </main>

    <script>
        // FUNGSI SEARCH (REDIRECT KE HALAMAN HISTORY)
        function searchTransaction() {
            const trxId = document.getElementById('searchTrxId').value.trim();
            if(!trxId) return alert('Masukkan ID Transaksi Anda!');
            
            // Redirect sesuai rute di server.js
            window.location.href = `/transaction/${trxId}`;
        }

        // Input Enter Trigger
        document.getElementById('searchTrxId').addEventListener('keypress', (e) => {
            if (e.key === 'Enter') searchTransaction();
        });

        // LOAD RECENT TRANSACTIONS MENGGUNAKAN FETCH API
        async function loadRecentTransactions() {
            try {
                const response = await fetch('/api/transactions/recent');
                const result = await response.json();
                
                if (result.status && result.data.length > 0) {
                    displayTransactions(result.data);
                } else {
                    document.getElementById('loadingTransactions').innerHTML = 
                        '<p class="text-gray-600 text-center py-8 font-bold uppercase text-[10px]">Belum ada transaksi</p>';
                }
            } catch (error) {
                console.error('Error:', error);
                document.getElementById('loadingTransactions').innerHTML = 
                    '<p class="text-red-500 text-center py-8 font-bold text-[10px]">GAGAL MEMUAT DATA</p>';
            }
        }

        function displayTransactions(transactions) {
            document.getElementById('loadingTransactions').classList.add('hidden');
            document.getElementById('transactionsTable').classList.remove('hidden');
            
            const tbody = document.getElementById('transactionsBody');
            tbody.innerHTML = '';

            transactions.forEach(trx => {
                // Masking ID: ORD-12345678 -> ORD-xxxx5678
                const maskedInvoice = trx.order_id.substring(0, 5) + '***' + trx.order_id.slice(-3);
                
                // Masking Target: 08123456789 -> 0812****89
                const target = trx.target || "N/A";
                const maskedTarget = target.length > 6 ? 
                    target.substring(0, 4) + '****' + target.slice(-2) : 
                    target;

                let statusBadge = '';
                if (trx.status === 'success') {
                    statusBadge = '<span class="text-green-400 font-black">SUCCESS</span>';
                } else if (trx.status === 'pending') {
                    statusBadge = '<span class="text-yellow-500 font-black">PENDING</span>';
                } else {
                    statusBadge = '<span class="text-red-500 font-black">FAILED</span>';
                }

                const row = `
                    <tr class="hover:bg-dark-700/30 transition-colors">
                        <td class="px-4 py-4 font-mono font-bold text-gray-300">${maskedInvoice}</td>
                        <td class="px-4 py-4 font-mono text-gray-400">${maskedTarget}</td>
                        <td class="px-4 py-4">${statusBadge}</td>
                    </tr>
                `;
                tbody.innerHTML += row;
            });
        }

        window.onload = loadRecentTransactions;
        
        function toggleSidebar() {
            const s = document.getElementById('sidebar');
            const o = document.getElementById('sidebarOverlay');
            s.classList.toggle('-translate-x-full');
            o.classList.toggle('hidden');
        }
    </script>
</body>
</html>
