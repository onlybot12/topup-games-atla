<!DOCTYPE html>
<html lang="id">
<head>
    <title>Lana Store - Topup Game & Digital</title>
    <%- include('../partials/user/heads') %>
    <style>
        .game-card { 
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1); 
            border-radius: 20px; 
            background: #1e293b; 
            border: 1px solid #334155; 
        }
        .game-card:active { transform: scale(0.92); background: #334155; }
        
        /* Animasi Slide Up untuk Order Sheet */
        @keyframes slideUp {
            from { transform: translateY(100%); }
            to { transform: translateY(0); }
        }
        .animate-slide-up { animation: slideUp 0.3s ease-out forwards; }
        
        .no-scrollbar::-webkit-scrollbar { display: none; }
    </style>
</head>
<body class="bg-dark-900 text-gray-100">

    <!-- Header -->
    <header class="sticky top-0 z-40 bg-dark-900/90 backdrop-blur-lg border-b border-dark-700 px-4 py-4 flex items-center gap-3">
        <button onclick="toggleSidebar()" class="w-10 h-10 flex items-center justify-center rounded-xl bg-dark-800 text-gray-400">
            <i class="fas fa-bars-staggered"></i>
        </button>
        <div class="flex-1 relative">
            <i class="fas fa-search absolute left-4 top-1/2 -translate-y-1/2 text-gray-500 text-xs"></i>
            <input type="text" id="searchInput" onkeyup="filterProducts()" placeholder="Cari Game atau Pulsa..." 
                class="w-full bg-dark-800 border-none rounded-full py-2.5 pl-10 pr-4 text-sm focus:ring-2 focus:ring-blue-500 outline-none">
        </div>
    </header>

    <%- include('../partials/sidebar-user') %>

    <main class="p-4 max-w-7xl mx-auto">
        <!-- Hero Banner -->
        <div class="bg-gradient-to-br from-blue-600 to-indigo-700 rounded-[32px] p-6 mb-8 shadow-xl shadow-blue-900/20 relative overflow-hidden">
            <div class="relative z-10">
                <h2 class="text-2xl font-black leading-tight">Topup Kilat,<br>Harga Sahabat.</h2>
                <p class="text-blue-100 text-[10px] mt-2 font-bold uppercase tracking-widest opacity-80">Otomatis 24 Jam Nonstop</p>
            </div>
            <i class="fas fa-bolt absolute -right-4 -bottom-4 text-8xl text-white/10 -rotate-12"></i>
        </div>

        <!-- Section List Kategori & Produk -->
        <div id="categoriesContainer" class="space-y-10">
            <!-- Loading State -->
            <div id="loading" class="flex flex-col items-center justify-center py-20">
                <div class="animate-spin h-10 w-10 border-4 border-blue-500 border-t-transparent rounded-full mb-4"></div>
                <p class="text-gray-500 text-sm font-bold">Menghubungkan ke Database...</p>
            </div>
        </div>
    </main>

    <!-- Order Sheet (Android Style Modal) -->
    <div id="orderSheet" class="fixed inset-0 z-50 hidden">
        <div class="absolute inset-0 bg-black/80 backdrop-blur-sm" onclick="closeSheet()"></div>
        <div class="absolute bottom-0 inset-x-0 bg-dark-800 rounded-t-[40px] p-6 shadow-2xl animate-slide-up max-h-[85vh] overflow-y-auto no-scrollbar border-t border-dark-700">
            <div class="w-12 h-1 bg-dark-600 rounded-full mx-auto mb-6"></div>
            
            <div class="flex items-center gap-4 mb-8">
                <img id="sheetImg" class="w-16 h-16 rounded-2xl object-cover border border-dark-600 shadow-lg">
                <div>
                    <h3 id="sheetTitle" class="font-black text-xl text-white"></h3>
                    <p id="sheetCat" class="text-blue-400 text-[10px] font-black uppercase tracking-wider"></p>
                </div>
            </div>

            <!-- Input Data Akun -->
            <div class="bg-dark-900/50 p-5 rounded-3xl border border-dark-700 mb-8">
                <label class="text-[10px] font-black text-gray-500 uppercase mb-3 block tracking-widest">Data Tujuan</label>
                
                <div id="mlInput" class="hidden grid grid-cols-7 gap-3">
                    <input type="tel" id="targetId" placeholder="User ID" class="col-span-4 bg-dark-900 border border-dark-700 rounded-xl p-4 text-sm focus:border-blue-500 outline-none font-bold">
                    <input type="tel" id="targetZone" placeholder="Zone" class="col-span-3 bg-dark-900 border border-dark-700 rounded-xl p-4 text-sm focus:border-blue-500 outline-none font-bold">
                </div>
                
                <div id="normalInput">
                    <input type="text" id="targetSingle" placeholder="Masukkan Nomor HP / ID Player" 
                        class="w-full bg-dark-900 border border-dark-700 rounded-xl p-4 text-sm focus:border-blue-500 outline-none font-bold">
                </div>
            </div>

            <!-- List Nominal -->
            <label class="text-[10px] font-black text-gray-500 uppercase mb-4 block tracking-widest ml-2">Pilih Nominal</label>
            <div id="sheetProducts" class="grid grid-cols-2 gap-3 pb-10">
                <!-- Produk akan muncul disini -->
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script>
        let allServices = [];
        let groupedData = {};

        // 1. Ambil data dari Backend
        window.onload = async () => {
            try {
                const res = await axios.get('/api/services');
                if(res.data.status) {
                    allServices = res.data.data;
                    processGrouping();
                }
            } catch (e) {
                document.getElementById('loading').innerHTML = '<p class="text-red-500">Gagal memuat data.</p>';
            }
        };

        // 2. Kelompokkan berdasarkan Brand
        function processGrouping() {
            groupedData = {};
            allServices.forEach(item => {
                // Pastikan menggunakan field brand atau provider
                const brand = item.brand || item.provider || "Lainnya";
                if(!groupedData[brand]) {
                    groupedData[brand] = {
                        name: brand,
                        category: item.category,
                        image: item.img_url,
                        items: []
                    };
                }
                groupedData[brand].items.push(item);
            });
            renderCategories();
        }

        // 3. Render Tampilan Utama
        function renderCategories() {
            const container = document.getElementById('categoriesContainer');
            const search = document.getElementById('searchInput').value.toLowerCase();
            const loading = document.getElementById('loading');
            if(loading) loading.remove();

            container.innerHTML = '';
            const categories = {};

            // Filter berdasarkan pencarian nama brand
            Object.values(groupedData).forEach(b => {
                if(b.name.toLowerCase().includes(search)) {
                    if(!categories[b.category]) categories[b.category] = [];
                    categories[b.category].push(b);
                }
            });

            if(Object.keys(categories).length === 0) {
                container.innerHTML = '<div class="text-center py-20 text-gray-500 font-bold">Produk tidak ditemukan</div>';
                return;
            }

            for(const [catName, brands] of Object.entries(categories)) {
                container.innerHTML += `
                    <div>
                        <h3 class="text-xs font-black text-gray-500 uppercase tracking-[0.2em] mb-4 ml-2 flex items-center gap-2">
                            <span class="w-1.5 h-4 bg-blue-600 rounded-full"></span> ${catName}
                        </h3>
                        <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 gap-4">
                            ${brands.map(b => `
                                <div onclick="openOrder('${b.name}')" class="game-card p-2 shadow-lg active:scale-95 transition-all cursor-pointer">
                                    <img src="${b.image}" class="w-full aspect-square object-cover rounded-2xl mb-2 shadow-inner border border-dark-700/50">
                                    <p class="text-[10px] font-black text-center truncate px-1 text-gray-200 uppercase tracking-tighter">${b.name}</p>
                                </div>
                            `).join('')}
                        </div>
                    </div>
                `;
            }
        }

        // 4. Buka Sheet Order
        function openOrder(brandName) {
            const group = groupedData[brandName];
            document.getElementById('sheetTitle').innerText = brandName;
            document.getElementById('sheetImg').src = group.image;
            document.getElementById('sheetCat').innerText = group.category;
            
            // Logika Input Mobile Legends
            const isML = brandName.toLowerCase().includes('mobile legends');
            document.getElementById('mlInput').classList.toggle('hidden', !isML);
            document.getElementById('normalInput').classList.toggle('hidden', isML);

            // Render Daftar Produk di Modal
            const list = document.getElementById('sheetProducts');
            list.innerHTML = '';
            
            // Urutkan harga dari yang termurah
            group.items.sort((a,b) => a.price_sell - b.price_sell).forEach(item => {
                list.innerHTML += `
                    <button onclick="createOrder('${item.service_id}')" 
                        class="bg-dark-900 border border-dark-700 p-4 rounded-2xl text-left hover:border-blue-500 active:bg-blue-900/50 transition-all flex flex-col justify-between h-full">
                        <p class="text-[10px] text-gray-400 font-bold mb-1 leading-tight">${item.name}</p>
                        <p class="text-sm font-black text-blue-400 mt-auto">Rp ${item.price_sell.toLocaleString('id-ID')}</p>
                    </button>
                `;
            });

            document.getElementById('orderSheet').classList.remove('hidden');
            document.body.style.overflow = 'hidden';
        }

        // 5. Kirim ke API Create Payment
        async function createOrder(service_id) {
            let target = '';
            const brand = document.getElementById('sheetTitle').innerText;
            const isML = brand.toLowerCase().includes('mobile legends');
            
            if(isML) {
                const id = document.getElementById('targetId').value;
                const zone = document.getElementById('targetZone').value;
                if(!id || !zone) return alert("Masukkan User ID dan Zone!");
                target = `${id}(${zone})`;
            } else {
                target = document.getElementById('targetSingle').value;
                if(!target) return alert("Masukkan ID/Nomor tujuan!");
            }

            try {
                // Memanggil API Create Payment (redirect ke QRIS)
                const res = await axios.post('/api/create-payment', { 
                    service_id, 
                    target, 
                    whatsapp: '628', // Placeholder, bisa ditambah input field WA di modal
                    email: 'customer@lanastore.com'
                });

                if(res.data.status) {
                    window.location.href = res.data.redirect_url;
                } else {
                    alert(res.data.message);
                }
            } catch (e) {
                alert("Gagal membuat pesanan.");
            }
        }

        function filterProducts() {
            renderCategories();
        }

        function closeSheet() {
            document.getElementById('orderSheet').classList.add('hidden');
            document.body.style.overflow = 'auto';
        }

        function toggleSidebar() {
            const s = document.getElementById('sidebar');
            const o = document.getElementById('sidebarOverlay');
            s.classList.toggle('-translate-x-full');
            o.classList.toggle('hidden');
        }
    </script>
</body>
</html>
