<!DOCTYPE html>
<html lang="id">
<head>
    <title>Lana Store - Topup Game & Digital</title>
    <%- include('../partials/user/heads') %>
    <style>
        .game-card { 
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1); 
            border-radius: 20px; 
            background: #1e293b; 
            border: 1px solid #334155; 
        }
        .game-card:active { transform: scale(0.92); background: #334155; }
        @keyframes slideUp { from { transform: translateY(100%); } to { transform: translateY(0); } }
        .animate-slide-up { animation: slideUp 0.3s ease-out forwards; }
        .no-scrollbar::-webkit-scrollbar { display: none; }
        body { padding-bottom: 100px; } /* Mencegah konten terpotong Bottom Nav */
    </style>
</head>
<body class="bg-dark-900 text-gray-100 overflow-x-hidden">

    <!-- Header -->
    <header class="sticky top-0 z-40 bg-dark-900/90 backdrop-blur-lg border-b border-dark-700 px-4 py-4 flex items-center gap-3">
        <button onclick="toggleSidebar()" class="w-10 h-10 flex items-center justify-center rounded-xl bg-dark-800 text-gray-400">
            <i class="fas fa-bars-staggered"></i>
        </button>
        <div class="flex-1 relative">
            <i class="fas fa-search absolute left-4 top-1/2 -translate-y-1/2 text-gray-500 text-xs"></i>
            <input type="text" id="searchInput" onkeyup="filterProducts()" placeholder="Cari Game, Pulsa, PLN..." 
                class="w-full bg-dark-800 border-none rounded-full py-2.5 pl-10 pr-4 text-sm focus:ring-2 focus:ring-blue-500 outline-none">
        </div>
    </header>

    <%- include('../partials/sidebar-user') %>

    <main class="p-4 max-w-7xl mx-auto min-h-screen pb-40">
        <!-- Hero Banner -->
        <div class="bg-gradient-to-br from-blue-600 to-indigo-700 rounded-[32px] p-6 mb-8 shadow-xl relative overflow-hidden">
            <div class="relative z-10">
                <h2 class="text-2xl font-black text-white leading-tight">Lana Store<br>Topup Otomatis.</h2>
                <p class="text-blue-100 text-[10px] mt-2 font-bold uppercase tracking-widest opacity-80">Proses Cepat 24 Jam Nonstop</p>
            </div>
            <i class="fas fa-bolt absolute -right-4 -bottom-4 text-8xl text-white/10 -rotate-12"></i>
        </div>

        <div id="categoriesContainer" class="space-y-10">
            <!-- Loading -->
            <div id="loading" class="flex flex-col items-center justify-center py-20">
                <div class="animate-spin h-10 w-10 border-4 border-blue-500 border-t-transparent rounded-full mb-4"></div>
                <p class="text-gray-500 text-xs font-bold uppercase">Memuat Layanan...</p>
            </div>
        </div>
    </main>

    <!-- Bottom Nav -->
    <nav class="fixed bottom-0 inset-x-0 bg-dark-800/95 backdrop-blur-md border-t border-dark-700 px-6 py-3 z-50 flex justify-around items-center shadow-2xl">
        <button onclick="switchPage('home')" class="flex flex-col items-center gap-1 text-blue-500">
            <i class="fas fa-home text-xl"></i><span class="text-[9px] font-black uppercase">Home</span>
        </button>
        <button onclick="switchPage('history')" class="flex flex-col items-center gap-1 text-gray-500">
            <i class="fas fa-receipt text-xl"></i><span class="text-[9px] font-black uppercase">Riwayat</span>
        </button>
        <button onclick="switchPage('faq')" class="flex flex-col items-center gap-1 text-gray-500">
            <i class="fas fa-question-circle text-xl"></i><span class="text-[9px] font-black uppercase">Bantuan</span>
        </button>
    </nav>

    <!-- Order Sheet -->
    <div id="orderSheet" class="fixed inset-0 z-50 hidden">
        <div class="absolute inset-0 bg-black/80 backdrop-blur-sm" onclick="closeSheet()"></div>
        <div class="absolute bottom-0 inset-x-0 bg-dark-800 rounded-t-[40px] p-6 shadow-2xl animate-slide-up max-h-[85vh] overflow-y-auto no-scrollbar border-t border-dark-700">
            <div class="w-12 h-1 bg-dark-600 rounded-full mx-auto mb-6"></div>
            
            <div class="flex items-center gap-4 mb-8">
                <img id="sheetImg" class="w-16 h-16 rounded-2xl object-cover border border-dark-600 shadow-lg">
                <div>
                    <h3 id="sheetTitle" class="font-black text-xl text-white"></h3>
                    <p id="sheetCat" class="text-blue-400 text-[10px] font-black uppercase"></p>
                </div>
            </div>

            <!-- Input Data -->
            <div class="bg-dark-900/50 p-5 rounded-3xl border border-dark-700 mb-6">
                <label class="text-[10px] font-black text-gray-500 uppercase mb-3 block tracking-widest">Data Tujuan</label>
                <div id="mlInput" class="hidden grid grid-cols-7 gap-2">
                    <input type="tel" id="targetId" placeholder="User ID" class="col-span-4 bg-dark-900 border border-dark-700 rounded-xl p-4 text-sm font-bold text-white outline-none focus:border-blue-500">
                    <input type="tel" id="targetZone" placeholder="Zone" class="col-span-3 bg-dark-900 border border-dark-700 rounded-xl p-4 text-sm font-bold text-white outline-none focus:border-blue-500">
                </div>
                <div id="normalInput">
                    <input type="text" id="targetSingle" placeholder="ID Player / Nomor HP" class="w-full bg-dark-900 border border-dark-700 rounded-xl p-4 text-sm font-bold text-white outline-none focus:border-blue-500">
                </div>
            </div>

            <!-- Nominal List -->
            <div id="sheetProducts" class="grid grid-cols-2 gap-3 pb-32"></div>
        </div>
    </div>

    <!-- Payment Confirm Modal -->
    <div id="confirmModal" class="fixed inset-0 z-[60] hidden flex items-center justify-center p-6">
        <div class="absolute inset-0 bg-black/90 backdrop-blur-md" onclick="closeConfirm()"></div>
        <div class="relative bg-dark-800 border border-dark-700 rounded-[32px] p-6 w-full max-w-sm shadow-2xl">
            <h3 class="font-black text-lg mb-6">Konfirmasi Pesanan</h3>
            <div class="space-y-3 mb-6 text-sm">
                <div class="flex justify-between text-gray-400"><span>Layanan</span><span id="sumItem" class="text-white font-bold text-right"></span></div>
                <div class="flex justify-between text-gray-400"><span>Tujuan</span><span id="sumTarget" class="text-blue-400 font-mono"></span></div>
                <div class="pt-4 border-t border-dark-700 flex justify-between items-center">
                    <span class="text-xs font-bold uppercase">Total Bayar</span>
                    <span id="sumTotal" class="text-xl font-black text-blue-500"></span>
                </div>
            </div>
            <div class="mb-6">
                <input type="tel" id="sumWA" placeholder="WhatsApp (628xxx)" class="w-full bg-dark-900 border border-dark-700 rounded-xl p-3 text-sm font-bold outline-none focus:border-blue-500">
            </div>
            <button onclick="executePayment()" id="btnPay" class="w-full bg-blue-600 py-4 rounded-2xl font-black shadow-lg">BAYAR SEKARANG</button>
        </div>
    </div>

    <script>
        let allServices = [];
        let groupedByBrand = {};
        let selectedProduct = null;

        // FETCH DATA MENGGUNAKAN FETCH API (Path absolut /api/services)
        window.onload = async () => {
            try {
                const response = await fetch('/api/services');
                const result = await response.json();
                if(result.status) {
                    allServices = result.data;
                    processData();
                }
            } catch (e) {
                console.error("Fetch error:", e);
                document.getElementById('loading').innerHTML = '<p class="text-red-500">Gagal Memuat Data</p>';
            }
        };

        function processData() {
            groupedByBrand = {};
            allServices.forEach(item => {
                if(!item.is_active) return;
                const brand = item.brand || "LAINNYA";
                if(!groupedByBrand[brand]) {
                    groupedByBrand[brand] = { name: brand, category: item.category, image: item.img_url, items: [] };
                }
                groupedByBrand[brand].items.push(item);
            });
            renderUI();
        }

        function renderUI() {
            const container = document.getElementById('categoriesContainer');
            const search = document.getElementById('searchInput').value.toLowerCase();
            if(document.getElementById('loading')) document.getElementById('loading').remove();
            container.innerHTML = '';
            
            const cats = {};
            Object.values(groupedByBrand).forEach(b => {
                if(b.name.toLowerCase().includes(search)) {
                    if(!cats[b.category]) cats[b.category] = [];
                    cats[b.category].push(b);
                }
            });

            for(const [catName, brands] of Object.entries(cats)) {
                container.innerHTML += `
                    <div>
                        <h3 class="text-[10px] font-black text-gray-500 uppercase tracking-[0.2em] mb-4 ml-2 flex items-center gap-2">
                            <span class="w-1 h-3 bg-blue-600 rounded-full"></span> ${catName}
                        </h3>
                        <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 gap-4">
                            ${brands.map(b => `
                                <div onclick="openOrder('${b.name}')" class="game-card p-2 shadow-lg cursor-pointer">
                                    <img src="${b.image}" class="w-full aspect-square object-cover rounded-2xl mb-2 border border-dark-700/50">
                                    <p class="text-[10px] font-black text-center truncate px-1 text-gray-300 uppercase">${b.name}</p>
                                </div>
                            `).join('')}
                        </div>
                    </div>
                `;
            }
        }

        function openOrder(brandName) {
            const group = groupedByBrand[brandName];
            document.getElementById('sheetTitle').innerText = brandName;
            document.getElementById('sheetImg').src = group.image;
            document.getElementById('sheetCat').innerText = group.category;
            
            const isML = brandName.toLowerCase().includes('mobile legends');
            document.getElementById('mlInput').classList.toggle('hidden', !isML);
            document.getElementById('normalInput').classList.toggle('hidden', isML);

            const list = document.getElementById('sheetProducts');
            list.innerHTML = '';
            group.items.sort((a,b) => a.price_sell - b.price_sell).forEach(item => {
                list.innerHTML += `
                    <button onclick="confirmOrder('${item.service_id}', '${item.name}', ${item.price_sell})" 
                        class="bg-dark-900 border border-dark-700 p-4 rounded-2xl text-left hover:border-blue-500 flex flex-col justify-between h-full group">
                        <p class="text-[10px] text-gray-400 font-bold mb-1 leading-tight group-hover:text-white">${item.name}</p>
                        <p class="text-sm font-black text-blue-400 mt-auto">Rp ${item.price_sell.toLocaleString('id-ID')}</p>
                    </button>
                `;
            });
            document.getElementById('orderSheet').classList.remove('hidden');
            document.body.style.overflow = 'hidden';
        }

        function confirmOrder(id, name, price) {
            let target = '';
            const title = document.getElementById('sheetTitle').innerText.toLowerCase();
            if(title.includes('mobile legends')) {
                const uid = document.getElementById('targetId').value;
                const zone = document.getElementById('targetZone').value;
                if(!uid || !zone) return alert("ID & Zone wajib diisi!");
                target = `${uid}(${zone})`;
            } else {
                target = document.getElementById('targetSingle').value;
                if(!target) return alert("Masukkan tujuan!");
            }

            selectedProduct = { id, name, price, target };
            document.getElementById('sumItem').innerText = name;
            document.getElementById('sumTarget').innerText = target;
            document.getElementById('sumTotal').innerText = "Rp " + price.toLocaleString('id-ID');
            document.getElementById('confirmModal').classList.remove('hidden');
        }

        async function executePayment() {
            const whatsapp = document.getElementById('sumWA').value;
            if(!whatsapp || whatsapp.length < 10) return alert("WA tidak valid!");
            
            const btn = document.getElementById('btnPay');
            btn.disabled = true; btn.innerText = "Processing...";

            try {
                const response = await fetch('/api/create-payment', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ service_id: selectedProduct.id, target: selectedProduct.target, whatsapp: whatsapp })
                });
                const result = await response.json();
                if(result.status) window.location.href = result.redirect_url;
                else alert(result.message);
            } catch (e) { alert("Error Server"); }
            btn.disabled = false; btn.innerText = "BAYAR SEKARANG";
        }

        function filterProducts() { renderUI(); }
        function closeSheet() { document.getElementById('orderSheet').classList.add('hidden'); document.body.style.overflow = 'auto'; }
        function closeConfirm() { document.getElementById('confirmModal').classList.add('hidden'); }
        function toggleSidebar() { document.getElementById('sidebar').classList.toggle('-translate-x-full'); document.getElementById('sidebarOverlay').classList.toggle('hidden'); }
    </script>
</body>
</html>
