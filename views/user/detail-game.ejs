<!DOCTYPE html>
<html lang="id">
<head>
    <title>Topup <%= brand.name %> - <%= config.shop_name %></title>
    <%- include('../partials/user/heads') %>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap');
        body { font-family: 'Plus Jakarta Sans', sans-serif; background-color: #0f172a; color: #f8fafc; }
        
        @keyframes slideUp { from { transform: translateY(100%); } to { transform: translateY(0); } }
        .animate-slide-up { animation: slideUp 0.3s ease-out forwards; }
        
        /* Efek Active pada Pilihan Nominal */
        .product-btn.active { 
            border-color: #3b82f6 !important; 
            background: rgba(59, 130, 246, 0.1); 
            box-shadow: 0 0 15px rgba(59, 130, 246, 0.3);
            transform: scale(0.98);
        }
        
        .no-scrollbar::-webkit-scrollbar { display: none; }
    </style>
</head>
<body class="pb-40 overflow-x-hidden">

    <!-- Header -->
    <header class="h-16 px-4 flex items-center gap-4 sticky top-0 z-40 bg-dark-900/90 backdrop-blur-lg border-b border-dark-800">
        <a href="/" class="w-10 h-10 bg-dark-800 rounded-xl flex items-center justify-center text-gray-400 active:scale-90 transition-all">
            <i class="fas fa-arrow-left"></i>
        </a>
        <div class="flex items-center gap-3">
            <img src="<%= brand.icon_url %>" class="w-9 h-9 rounded-xl object-cover shadow-lg border border-dark-700">
            <h1 class="font-black text-sm uppercase tracking-tight text-white"><%= brand.name %></h1>
        </div>
    </header>

    <main class="p-4 max-w-3xl mx-auto">

        <!-- ==========================================
             TAMBAHAN: BAGIAN DETAIL / DESKRIPSI GAME 
             ========================================== -->
        <div class="bg-dark-800 border border-dark-700 rounded-[32px] p-6 mb-6 shadow-xl reveal">
            <div class="flex items-center gap-2 mb-4">
                <i class="fas fa-info-circle text-blue-500 text-sm"></i>
                <h3 class="text-[10px] font-black text-gray-400 uppercase tracking-widest">Informasi & Cara Topup</h3>
            </div>
            <div class="text-[11px] text-gray-300 leading-relaxed space-y-2 font-medium">
                <!-- Deskripsi dinamis dari database -->
                <%- brand.description || 'Topup ' + brand.name + ' Otomatis 24 Jam. Masukkan data akun Anda dengan benar, pilih nominal, dan selesaikan pembayaran. Pesanan akan diproses secara instan setelah pembayaran terverifikasi.' %>
            </div>
        </div>
        
        <!-- STEP 1: FORM DATA TUJUAN -->
        <div class="bg-dark-800 border border-dark-700 rounded-[32px] p-6 mb-6 shadow-xl reveal">
            <div class="flex items-center gap-2 mb-5">
                <span class="w-6 h-6 bg-blue-600 text-white text-[10px] font-black rounded-full flex items-center justify-center">1</span>
                <label class="text-[10px] font-black text-gray-400 uppercase tracking-widest">Lengkapi Data Akun</label>
            </div>
            
            <div class="grid grid-cols-1 gap-5">
                <div>
                    <p class="text-[10px] font-bold text-slate-500 uppercase mb-2 ml-1"><%= brand.form_config.target_label %></p>
                    <input type="<%= brand.form_config.target_type %>" id="target1" placeholder="Masukkan <%= brand.form_config.target_label %>" 
                        class="w-full bg-dark-900 border border-dark-700 rounded-2xl p-4 text-sm font-bold text-white focus:border-blue-500 outline-none transition-all">
                </div>

                <% if(brand.form_config.has_server) { %>
                <div>
                    <p class="text-[10px] font-bold text-slate-500 uppercase mb-2 ml-1"><%= brand.form_config.server_label %></p>
                    <input type="<%= brand.form_config.server_type %>" id="target2" placeholder="Masukkan <%= brand.form_config.server_label %>" 
                        class="w-full bg-dark-900 border border-dark-700 rounded-2xl p-4 text-sm font-bold text-white focus:border-blue-500 outline-none transition-all">
                </div>
                <% } %>

                <!-- DISPLAY NICKNAME (VALIDASI ID) -->
                <div id="nickname-display" class="hidden animate-pulse p-3 bg-blue-600/10 border border-blue-500/20 rounded-2xl">
                    <p class="text-[9px] font-black text-blue-400 uppercase tracking-widest leading-none">Nickname Akun:</p>
                    <p id="player-name" class="text-sm font-black text-white mt-1 uppercase"></p>
                </div>
            </div>
        </div>

        <!-- STEP 2: PILIH PRODUK -->
        <div class="flex items-center gap-2 mb-4 ml-2">
            <span class="w-6 h-6 bg-blue-600 text-white text-[10px] font-black rounded-full flex items-center justify-center">2</span>
            <h3 class="text-[10px] font-black text-gray-400 uppercase tracking-widest">Pilih Nominal Topup</h3>
        </div>

        <div class="grid grid-cols-2 gap-3 mb-10">
            <% if (products.length > 0) { %>
                <% products.forEach(p => { %>
                    <button onclick="selectProduct(this, '<%= p.service_id %>', '<%= p.name %>', <%= p.price_sell %>)" 
                        class="product-btn bg-dark-800 border border-dark-700 p-4 rounded-2xl text-left hover:border-blue-500 transition-all flex flex-col justify-between h-full active:scale-95">
                        <p class="text-[10px] text-gray-400 font-bold mb-2 leading-tight uppercase"><%= p.name %></p>
                        <p class="text-sm font-black text-blue-400 mt-auto">Rp <%= p.price_sell.toLocaleString('id-ID') %></p>
                    </button>
                <% }) %>
            <% } else { %>
                <div class="col-span-2 py-20 text-center bg-dark-800 border border-dashed border-dark-700 rounded-3xl">
                    <p class="text-gray-500 text-xs font-bold uppercase tracking-widest">Layanan belum tersedia</p>
                </div>
            <% } %>
        </div>

        <!-- STEP 3: CHECKOUT BOX (VOUCHER & TOTAL) -->
        <div id="checkoutBox" class="hidden space-y-4 animate-slide-up">
            
            <!-- VOUCHER PROMO -->
            <div class="bg-dark-800 border border-dark-700 rounded-[32px] p-6 shadow-xl">
                <div class="flex items-center gap-2 mb-4">
                    <span class="w-6 h-6 bg-blue-600 text-white text-[10px] font-black rounded-full flex items-center justify-center">3</span>
                    <h3 class="text-[10px] font-black text-gray-400 uppercase tracking-widest">Kode Voucher (Opsional)</h3>
                </div>
                <div class="flex gap-2">
                    <input type="text" id="vCode" placeholder="DISKON79" class="flex-1 bg-dark-900 border border-dark-700 rounded-2xl px-4 py-3 uppercase text-sm font-bold text-white outline-none focus:border-blue-500">
                    <button onclick="checkVoucher()" id="btnCheckVoucher" class="bg-blue-600 text-white px-6 py-3 rounded-2xl text-xs font-black uppercase active:scale-90 transition-all">Cek</button>
                </div>
                <p id="voucherMsg" class="text-[10px] mt-2 font-bold uppercase"></p>
            </div>

            <!-- RINGKASAN PEMBAYARAN -->
            <div class="bg-dark-800 border border-dark-700 rounded-[32px] p-6 shadow-2xl">
                <div class="space-y-3 mb-6 border-b border-dark-700 pb-6">
                    <div class="flex justify-between text-xs">
                        <span class="text-gray-500 font-bold uppercase">Harga Item</span>
                        <span id="displayBasePrice" class="text-white font-black">Rp 0</span>
                    </div>
                    <div id="displayDiscRow" class="hidden flex justify-between text-xs text-green-400 font-black">
                        <span>Potongan Diskon</span>
                        <span id="displayDiscPrice">- Rp 0</span>
                    </div>
                </div>
                
                <div class="flex justify-between items-center mb-8">
                    <span class="text-xs font-black text-white uppercase tracking-widest">Total Tagihan</span>
                    <span id="displayFinalPrice" class="text-2xl font-black text-blue-500">Rp 0</span>
                </div>

                <div class="mb-6">
                    <label class="text-[10px] font-black text-gray-500 uppercase mb-2 block ml-1 tracking-widest">Nomor WhatsApp</label>
                    <input type="tel" id="wa" placeholder="Contoh: 0812345678" 
                        class="w-full bg-dark-900 border border-dark-700 rounded-2xl p-4 text-sm font-bold text-white outline-none focus:border-blue-500 transition-all">
                </div>

                <button onclick="processPayment()" id="btnPay" class="w-full bg-blue-600 text-white py-5 rounded-[24px] font-black text-sm shadow-xl shadow-blue-900/40 active:scale-95 transition-all uppercase tracking-widest">
                    <i class="fas fa-credit-card mr-2"></i> Bayar Sekarang
                </button>
            </div>
        </div>
    </main>

    <script>
        let selectedProduct = null;
        let appliedDiscount = 0;
        let appliedVoucherCode = null;

        // DATA DARI BACKEND UNTUK SCRIPT
        const valCode = "<%= brand.validation_code %>";

        // 1. Pilih Produk
        function selectProduct(element, id, name, price) {
            document.querySelectorAll('.product-btn').forEach(btn => btn.classList.remove('active'));
            element.classList.add('active');

            selectedProduct = { id, name, price };
            appliedDiscount = 0; 
            appliedVoucherCode = null;
            document.getElementById('voucherMsg').innerText = "";
            document.getElementById('vCode').value = "";

            document.getElementById('checkoutBox').classList.remove('hidden');
            updatePriceUI();
            
            setTimeout(() => {
                document.getElementById('checkoutBox').scrollIntoView({ behavior: 'smooth', block: 'start' });
            }, 100);
        }

        // 2. Fungsi Cek Voucher
        async function checkVoucher() {
            const code = document.getElementById('vCode').value.toUpperCase();
            if(!code) return;
            const btn = document.getElementById('btnCheckVoucher');
            const msg = document.getElementById('voucherMsg');
            btn.disabled = true; btn.innerText = "...";
            try {
                const response = await fetch('/api/vouchers/verify', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ code: code, amount: selectedProduct.price })
                });
                const result = await response.json();
                if(result.status) {
                    appliedDiscount = result.discount;
                    appliedVoucherCode = result.code;
                    msg.innerText = "✓ Voucher Terpasang";
                    msg.className = "text-[10px] mt-2 font-bold text-green-400 uppercase";
                } else {
                    appliedDiscount = 0; appliedVoucherCode = null;
                    msg.innerText = "✕ " + result.message;
                    msg.className = "text-[10px] mt-2 font-bold text-red-500 uppercase";
                }
                updatePriceUI();
            } catch (e) { alert("Server error"); }
            finally { btn.disabled = false; btn.innerText = "CEK"; }
        }

        // 3. Update Harga UI
        async function updatePriceUI() {
            const basePrice = selectedProduct.price;
            try {
                const confRes = await fetch('/api/admin/config');
                const confJson = await confRes.json();
                const config = confJson.data;
                let priceAfterVoucher = basePrice - appliedDiscount;
                const multiplier = (100 - config.tax_percent) / 100;
                const totalBayar = Math.ceil((priceAfterVoucher + config.admin_fee) / multiplier);

                document.getElementById('displayBasePrice').innerText = "Rp " + basePrice.toLocaleString('id-ID');
                document.getElementById('displayFinalPrice').innerText = "Rp " + totalBayar.toLocaleString('id-ID');
                const discRow = document.getElementById('displayDiscRow');
                if(appliedDiscount > 0) {
                    discRow.classList.remove('hidden');
                    document.getElementById('displayDiscPrice').innerText = "- Rp " + appliedDiscount.toLocaleString('id-ID');
                } else {
                    discRow.classList.add('hidden');
                }
            } catch (e) { console.error("Config error"); }
        }

        // 4. Validasi ID Game (Nickname)
        async function validatePlayer() {
            if (!valCode) return;
            const id = document.getElementById('target1').value;
            const server = document.getElementById('target2') ? document.getElementById('target2').value : '';
            const display = document.getElementById('nickname-display');
            const nameTxt = document.getElementById('player-name');

            if (id.length < 4) { display.classList.add('hidden'); return; }

            nameTxt.innerText = "Mengecek ID...";
            display.classList.remove('hidden');

            try {
                const res = await fetch(`/api/validasi/${valCode}?id=${id}&server=${server}`);
                const result = await res.json();
                if (result.success) {
                    nameTxt.innerText = result.nickname;
                    nameTxt.classList.replace('text-red-400', 'text-white');
                } else {
                    nameTxt.innerText = "ID Tidak Ditemukan";
                    nameTxt.classList.replace('text-white', 'text-red-400');
                }
            } catch (e) { display.classList.add('hidden'); }
        }

        // Event Listener untuk Auto Check ID
        let valTimeout = null;
        document.querySelectorAll('#target1, #target2').forEach(el => {
            el.addEventListener('keyup', () => {
                clearTimeout(valTimeout);
                valTimeout = setTimeout(validatePlayer, 1200);
            });
        });

        // 5. Eksekusi Pembayaran
    async function processPayment() {
    const t1 = document.getElementById('target1').value;
    const t2 = document.getElementById('target2') ? document.getElementById('target2').value : '';
    const wa = document.getElementById('wa').value;
    const v = document.getElementById('vCode').value;

    if(!t1 || !wa) return alert("Harap lengkapi data tujuan dan WhatsApp!");

    const btn = document.getElementById('btnPay');
    btn.disabled = true;
    btn.innerHTML = `<i class="fas fa-spinner fa-spin mr-2"></i> MENGALIHKAN...`;

    try {
        const response = await fetch('/api/create-payment', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ 
                service_id: selectedProduct.id, 
                target1: t1,      // Kirim ID Mentah
                target2: t2,      // Kirim Server Mentah
                whatsapp: wa, 
                voucher_code: v 
            })
        });
        
        const result = await response.json();
        if(result.status) {
            window.location.href = result.redirect_url;
        } else {
            alert(result.message);
            btn.disabled = false;
            btn.innerHTML = `BAYAR SEKARANG`;
        }
    } catch (e) {
        alert("Server error");
        btn.disabled = false;
    }
}


</script>
</body>
</html>
