<!DOCTYPE html>
<html lang="id">
<head>
    <title>Lana Store - Topup Game Murah & Cepat</title>
    <%- include('../partials/user/heads') %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');
        
        body { 
            background-color: #0f172a; 
            color: #f8fafc; 
            overflow-x: hidden; 
            font-family: 'Plus Jakarta Sans', sans-serif;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }
        main { flex: 1; }

        .glass { background: rgba(30, 41, 59, 0.7); backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.05); }
        
        /* Main Brand Card (3 Kolom) */
        .brand-card-main { 
            transition: all 0.3s ease;
            background: #1e293b;
            border: 1px solid #334155;
            border-radius: 20px;
        }
        .brand-item img {
            width: 100%;
            aspect-ratio: 1/1;
            object-fit: cover;
            border-radius: 16px;
        }

        /* Popular Section (Layout seperti gambar, Warna tetap Dark) */
        .popular-container {
            background-color: #1e293b; /* Warna gelap konsisten */
            border-radius: 28px;
            padding: 24px;
            border: 1px solid #334155;
        }
        .popular-card {
            background-color: #0f172a; /* Card lebih gelap dari container */
            border-radius: 18px;
            padding: 12px;
            display: flex;
            align-items: center;
            gap: 14px;
            transition: all 0.2s;
            border: 1px solid rgba(255,255,255,0.05);
        }
        .popular-card:active { transform: scale(0.96); background-color: #1e293b; }
        .popular-card img {
            width: 52px;
            height: 52px;
            border-radius: 12px;
            object-fit: cover;
        }

        .category-tabs::-webkit-scrollbar { display: none; }
        .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    </style>
</head>
<body>

    <%- include('../partials/sidebar-user') %>

    <!-- NAVBAR -->
    <header class="sticky top-0 z-50 glass border-b border-slate-800 px-4 py-3">
        <div class="max-w-7xl mx-auto flex items-center justify-between gap-4">
            <button onclick="toggleSidebar()" class="w-10 h-10 flex items-center justify-center rounded-xl bg-slate-800 text-white active:scale-90 transition-all">
                <i class="fas fa-bars-staggered"></i>
            </button>
            <div class="flex-1 relative">
                <i class="fas fa-search absolute left-4 top-1/2 -translate-y-1/2 text-slate-500 text-xs"></i>
                <input type="text" id="searchInput" onkeyup="searchGame()" placeholder="Cari Game Favorit..." 
                    class="w-full bg-slate-900 border border-slate-700 rounded-full py-2.5 pl-10 pr-4 text-sm focus:ring-2 focus:ring-blue-500 outline-none transition-all">
            </div>
            <span class="font-bold text-blue-500 text-xl tracking-tighter">LANA</span>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 mt-6 w-full">

        <!-- 1. BANNER SLIDER -->
        <% if (typeof banners !== 'undefined' && banners.length > 0) { %>
        <div class="swiper mainSwiper rounded-[24px] overflow-hidden shadow-2xl mb-10">
            <div class="swiper-wrapper">
                <% banners.forEach(b => { %>
                <div class="swiper-slide">
                    <a href="<%= b.target_link %>">
                        <img src="<%= b.image_url %>" class="w-full aspect-[21/9] object-cover" alt="Promo">
                    </a>
                </div>
                <% }) %>
            </div>
            <div class="swiper-pagination"></div>
        </div>
        <% } %>

        <!-- 2. POPULER SEKARANG (STYLE LAYANAN SESUAI GAMBAR) -->
        <% const popularBrands = brands.filter(b => b.is_popular); %>
        <% if (popularBrands.length > 0) { %>
        <section class="popular-container mb-10 shadow-lg">
            <div class="flex items-center gap-2 mb-1">
                <span class="text-xl">⚠️</span>
                <h3 class="font-bold text-white uppercase text-lg leading-none tracking-tight">Populer Sekarang!</h3>
            </div>
            <p class="text-slate-400 text-xs mb-6 ml-1 font-medium">Beberapa produk yang paling populer saat ini.</p>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <% popularBrands.forEach(brand => { %>
                <a href="/id/<%= brand.slug %>" class="popular-card">
                    <img src="<%= brand.icon_url %>" alt="<%= brand.name %>">
                    <div class="overflow-hidden">
                        <p class="font-bold text-white text-sm uppercase truncate tracking-wide"><%= brand.name %></p>
                        <p class="text-slate-500 text-[10px] font-bold uppercase"><%= brand.category %></p>
                    </div>
                </a>
                <% }) %>
            </div>
        </section>
        <% } %>

        <!-- 3. DAFTAR GAME (3 Kolom per baris di HP) -->
        <section class="mb-20">
            <div class="category-tabs flex gap-2 overflow-x-auto pb-4 mb-6 hide-scrollbar">
                <button onclick="filterCat('All')" class="cat-btn px-5 py-2 rounded-full bg-blue-600 text-white text-xs font-bold uppercase shadow-lg">Semua</button>
                <% [...new Set(brands.map(b => b.category))].forEach(cat => { %>
                <button onclick="filterCat('<%= cat %>')" class="cat-btn px-5 py-2 rounded-full bg-slate-800 text-slate-400 text-xs font-bold uppercase hover:bg-slate-700 transition-all"><%= cat %></button>
                <% }) %>
            </div>

            <div id="gameGrid" class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-6 gap-3 sm:gap-6">
                <% brands.forEach(brand => { %>
                <a href="/id/<%= brand.slug %>" data-category="<%= brand.category %>" class="brand-item flex flex-col group transition-all">
                    <div class="brand-card-main p-1.5 mb-2 shadow-xl border border-slate-700">
                        <img src="<%= brand.icon_url %>" alt="<%= brand.name %>">
                    </div>
                    <p class="text-[10px] font-bold text-center text-slate-200 uppercase truncate w-full px-0.5"><%= brand.name %></p>
                </a>
                <% }) %>
            </div>
        </section>

    </main>

    <!-- FOOTER (Clean & Standard) -->
    <footer class="border-t border-slate-800 py-12 px-6 bg-[#0a0f1a]">
        <div class="max-w-7xl mx-auto flex flex-col items-center text-center">
            <h2 class="text-2xl font-bold text-blue-500 mb-4 tracking-tight">LANA STORE</h2>
            <p class="text-sm text-slate-400 max-w-md mb-8 leading-relaxed font-medium">
                Platform top-up game termurah, tercepat, dan terpercaya di Indonesia. Otomatis 24 jam nonstop dengan berbagai metode pembayaran aman.
            </p>
            
            <div class="flex gap-8 mb-10">
                <% if(config.wa_link) { %><a href="<%= config.wa_link %>" class="text-slate-400 hover:text-green-500 transition-colors text-xl"><i class="fab fa-whatsapp"></i></a><% } %>
                <% if(config.ig_link) { %><a href="<%= config.ig_link %>" class="text-slate-400 hover:text-pink-500 transition-colors text-xl"><i class="fab fa-instagram"></i></a><% } %>
                <% if(config.tiktok_link) { %><a href="<%= config.tiktok_link %>" class="text-slate-400 hover:text-white transition-colors text-xl"><i class="fab fa-tiktok"></i></a><% } %>
            </div>
            
            <div class="w-full max-w-xs h-px bg-slate-800 mb-8 opacity-30"></div>
            
            <p class="text-xs text-slate-500 font-bold tracking-widest uppercase">
                © 2026 LANA STORE • ALL RIGHTS RESERVED
            </p>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.7.0.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
    
    <script>
        const swiper = new Swiper(".mainSwiper", {
            loop: true,
            autoplay: { delay: 4000 },
            pagination: { el: ".swiper-pagination", clickable: true },
        });

        function filterCat(cat) {
            $('.cat-btn').removeClass('bg-blue-600 text-white shadow-lg').addClass('bg-slate-800 text-slate-400');
            $(event.target).addClass('bg-blue-600 text-white shadow-lg').removeClass('bg-slate-800 text-slate-400');
            if(cat === 'All') { $('.brand-item').show(); } 
            else { $('.brand-item').hide(); $(`.brand-item[data-category="${cat}"]`).show(); }
        }

        function searchGame() {
            let val = $('#searchInput').val().toLowerCase();
            $('.brand-item').each(function() {
                let name = $(this).find('p').text().toLowerCase();
                $(this).toggle(name.includes(val));
            });
        }
    </script>
</body>
</html>
