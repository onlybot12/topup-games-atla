<!DOCTYPE html>
<html lang="id">
<head>
    <title>Lana Store - Topup Game</title>
    <%- include('../partials/user/heads') %>
    <style>
        .brand-card { background: #1e293b; border: 1px solid #334155; border-radius: 24px; transition: all 0.2s; }
        .brand-card:active { transform: scale(0.92); background: #334155; }
    </style>
</head>
<body class="bg-dark-900 text-white">

    <%- include('../partials/sidebar-user') %>

    <header class="h-16 px-4 flex items-center justify-between sticky top-0 z-40 bg-dark-900/80 backdrop-blur-md">
        <button onclick="toggleSidebar()" class="w-10 h-10 bg-dark-800 rounded-xl flex items-center justify-center text-gray-400"><i class="fas fa-bars-staggered"></i></button>
        <span class="font-black text-blue-500 tracking-tighter">LANA STORE</span>
        <div class="w-10"></div>
    </header>

    <main class="p-4 max-w-7xl mx-auto">
        <!-- Loop Kategori dari Brand -->
        <% const cats = [...new Set(brands.map(b => b.category))]; %>
        <% cats.forEach(cat => { %>
            <div class="mb-10">
                <h3 class="text-xs font-black text-gray-500 uppercase tracking-widest mb-4 ml-2"><i class="fas fa-tag mr-2"></i><%= cat %></h3>
                <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 gap-4">
                    <% brands.filter(b => b.category === cat).forEach(brand => { %>
                        <a href="/id/<%= brand.slug %>" class="brand-card p-2 flex flex-col items-center">
                            <img src="<%= brand.icon_url %>" class="w-full aspect-square object-cover rounded-2xl mb-2">
                            <p class="text-[10px] font-bold text-center truncate w-full px-1 uppercase tracking-tighter"><%= brand.name %></p>
                        </a>
                    <% }) %>
                </div>
            </div>
        <% }) %>
    </main>

</body>
</html>
